!% -~S
!% -Cu
!% $OMIT_UNUSED_ROUTINES=1
!% $ZCODE_LESS_DICT_DATA=1
!% $LONG_DICT_FLAG_BUG=0
!% $ZCODE_COMPACT_GLOBALS=1
!% $MAX_ABBREVS=96

Include ">abbrvs.h";
Constant GAME_ABBREVS;
Include "chartable_de.h";   ! MUST be first

Constant Story      "Staub";
Constant Headline   "^Ein Western von IkeC^";
Release 4;
Array UUID_ARRAY string "UUID://506FA077-9940-404A-B9FB-907CD4C773D2//";
#Ifdef UUID_ARRAY;#Endif;

Constant NO_SCORE = 1;
Constant OPTIONAL_SL_NO_SCORE;
Constant OPTIONAL_SL_NO_MOVES;
Constant CUSTOM_PLAYER_OBJECT = Tom;
Constant OPTIONAL_NO_DARKNESS;
Constant OPTIONAL_FULL_DIRECTIONS;
Constant OPTIONAL_EXTENDED_METAVERBS;
Constant OPTIONAL_SIMPLE_DOORS;
Constant RUNTIME_ERRORS = 0;
Constant INITIAL_LOCATION_VALUE = r_Zimmer;
Constant FLAG_COUNT = 60;

Include "globals.h";

Property cheap_scenery;
Attribute ablegbar;
Include "ext_flags.h";

Object Tom "du"
    with name 'mich' 'mir' 'ich' 'selbst' 'tom',
        short_name "dich selbst",
        description "Du hast schon schlimmer ausgesehen, aber ein Bad und eine Rasur könnten nicht schaden.",
        before [;
            Smell:
                if (noun == player) rfalse;
                "Dein letztes Bad ist schon eine Weile her, und das riecht man auch durchaus. Unangenehm auffallen solltest du damit in dieser Gegend allerdings (noch) nicht.";
        ],
    has concealed animate proper transparent;

Include "ext_talk_menu_inline_de.h";
Include "ext_cheap_scenery_de.h";
Include "puny.h";

Verb 'info' 'hilfe'
    *                                           -> Info;
Verb 'tipp' 'tip' 'hinweis'
    *                                           -> Hint;
Verb 'credits' 'impressum'
    *                                           -> Credits;
Verb 'benutz'
    *                                           -> UseOnly
    * noun                                      -> Use
    * noun 'mit'/'auf'/'in'/'an' noun           -> UseTogether;

Verb 'schiess' 'erschieß'
    *                                           -> UseOnly
    * 'auf' noun                                -> Use
    * 'auf' noun 'mit' noun                     -> UseTogether
    * noun                                      -> Use
    * noun 'mit' noun                           -> UseTogether;

Extend 'lauf' last
    * 'zu'/'zur'/'nach' topic                   -> LaufZu
    * topic                                     -> LaufZu
    * ->                                           LaufOnly;

[PrintDescOOB;
    print "Es gibt ";
    switch (random(3)) {
        1: print "nichts für dich dort draußen zu sehen";
        2: print "nur vertrocknetes Steppengras dort draußen";
        3: print "nichts außer Staub und Sand in dieser Richtung";
    }
    print ", und du solltest dich auch nicht noch weiter aus der Stadt entfernen.";
    new_line;
    rtrue;
];

[PrintDescLaufen;
    style underline;
    switch (random(5)) {
        1, 5: print "Kurze Zeit später...";
        2:    print "Einige Schritte später...";
        3:    print "Ein paar Minuten später...";
        4:    print "Kurz darauf...";
    }
    style roman;
    new_line;
];

[PrintBekannteLaufOrte;
    print "^";
    if (r_Zimmer has visited)      print "- Zimmer^";
    if (r_Saloon has visited)      print "- Saloon (Ella)^";
    if (r_Hauptstrasse has visited) print "- Main Street^";
    if (r_Sheriff has visited)     print "- Büro des Sheriffs (Dunder)^";
    if (r_Laden has visited)       print "- Laden (Bill)^";
    if (r_Barbier has visited)     print "- Barbier (Marten)^";
    if (r_Ranch has visited)       print "- Ranch^";
    if (r_Galgen has visited)      print "- Galgen^";
    if (r_Friedhof has visited)    print "- Friedhof^";
    if (r_Mine has visited)        print "- Mine^";
    if (r_Windrad has visited)     print "- Windrad^";
    if (r_Huegelkette has visited) print "- Hügelkette^";
    if (r_Hoehle has visited)      print "- Höhle^";
    if (r_Gewoelbe has visited)    print "- Gewölbe^";
];

[LaufOnlySub;
    print "LAUF ZU einem dieser Orte:";
    PrintBekannteLaufOrte();
];

[LaufZuSub _w _len _dest;
    _w = WordAddress(consult_from);
    _len = WordLength(consult_from);

    if      (_len >= 6 && _w->0=='z' && _w->1=='i' && _w->2=='m' && _w->3=='m' && _w->4=='e' && _w->5=='r') _dest = r_Zimmer;
    else if (_len >= 6 && _w->0=='s' && _w->1=='a' && _w->2=='l' && _w->3=='o' && _w->4=='o' && _w->5=='n') _dest = r_Saloon;
    else if (_len >= 4 && _w->0=='e' && _w->1=='l' && _w->2=='l' && _w->3=='a')                             _dest = r_Saloon;
    else if (_len >= 4 && _w->0=='m' && _w->1=='a' && _w->2=='i' && _w->3=='n')                             _dest = r_Hauptstrasse;
    else if (_len >= 7 && _w->0=='s' && _w->1=='t' && _w->2=='r' && _w->3=='a' && _w->4=='s' && _w->5=='s' && _w->6=='e') _dest = r_Hauptstrasse;
    else if (_len >= 7 && _w->0=='s' && _w->1=='h' && _w->2=='e' && _w->3=='r' && _w->4=='i' && _w->5=='f' && _w->6=='f') _dest = r_Sheriff;
    else if (_len >= 6 && _w->0=='d' && _w->1=='u' && _w->2=='n' && _w->3=='d' && _w->4=='e' && _w->5=='r') _dest = r_Sheriff;
    else if (_len >= 5 && _w->0=='l' && _w->1=='a' && _w->2=='d' && _w->3=='e' && _w->4=='n')               _dest = r_Laden;
    else if (_len >= 4 && _w->0=='b' && _w->1=='i' && _w->2=='l' && _w->3=='l')                             _dest = r_Laden;
    else if (_len >= 7 && _w->0=='b' && _w->1=='a' && _w->2=='r' && _w->3=='b' && _w->4=='i' && _w->5=='e' && _w->6=='r') _dest = r_Barbier;
    else if (_len >= 6 && _w->0=='m' && _w->1=='a' && _w->2=='r' && _w->3=='t' && _w->4=='e' && _w->5=='n') _dest = r_Barbier;
    else if (_len >= 5 && _w->0=='r' && _w->1=='a' && _w->2=='n' && _w->3=='c' && _w->4=='h')               _dest = r_Ranch;
    else if (_len >= 6 && _w->0=='g' && _w->1=='a' && _w->2=='l' && _w->3=='g' && _w->4=='e' && _w->5=='n') _dest = r_Galgen;
    else if (_len >= 8 && _w->0=='f' && _w->1=='r' && _w->2=='i' && _w->3=='e' && _w->4=='d' && _w->5=='h' && _w->6=='o' && _w->7=='f') _dest = r_Friedhof;
    else if (_len >= 4 && _w->0=='m' && _w->1=='i' && _w->2=='n' && _w->3=='e')                             _dest = r_Mine;
    else if (_len >= 7 && _w->0=='w' && _w->1=='i' && _w->2=='n' && _w->3=='d' && _w->4=='r' && _w->5=='a' && _w->6=='d') _dest = r_Windrad;
    ! hügelkette (h + ü=252) or huegelkette (h + u):
    else if (_len >= 2 && _w->0=='h' && (_w->1==252 || _w->1=='u'))                                         _dest = r_Huegelkette;
    ! höhle (h + ö=246) or hoehle (h + o):
    else if (_len >= 2 && _w->0=='h' && (_w->1==246 || _w->1=='o'))                                         _dest = r_Hoehle;
    ! gewölbe (g+e+w) or gewoelbe:
    else if (_len >= 3 && _w->0=='g' && _w->1=='e' && _w->2=='w')                                           _dest = r_Gewoelbe;
    else {
        print "Diesen Ort kenne ich nicht. Bekannte Orte:";
        PrintBekannteLaufOrte();
        rtrue;
    }

    if (_dest hasnt visited)
        "Diesen Ort kenne ich noch nicht.";
    if (player in _dest)
        "Da bist du doch schon!";
    if (Stange in player && (_dest == r_Zimmer || _dest == r_Saloon || _dest == r_Hauptstrasse ||
        _dest == r_Sheriff || _dest == r_Laden || _dest == r_Barbier || _dest == r_Ranch ||
        _dest == r_Galgen || _dest == r_Friedhof))
        "Mit der langen Metallstange solltest du dich in der Stadt nicht blicken lassen.";
    PrintDescLaufen();
    PlayerTo(_dest);
];

[UseOnlySub; "Was möchtest du benutzen?"; ];
[UseSub; print "Ich weiß nicht, wie man "; print (the) noun; " benutzt."; ];
[UseTogetherSub;
    ! Lampe + Streichhölzer (light lamp)
    if ((noun == Lampe && second == Streichhoelzer) ||
        (noun == Streichhoelzer && second == Lampe)) {
        if (Streichhoelzer notin player) "Du hast keine Streichhölzer.";
        if (Lampe notin player) "Du hast keine Lampe.";
        <<SwitchOn Lampe>>;
    }
    ! Schaufel + Sand (dig at Galgen)
    if ((noun == Schaufel && second == GalgenSand) ||
        (noun == GalgenSand && second == Schaufel)) {
        if (Schaufel notin player) "Du hast die Schaufel nicht dabei.";
        if (player notin r_Galgen) "Hier gibt es nichts Sinnvolles zu graben.";
        if (FlagIsSet(F_PLATFORM_DUG)) "Du bist mit dem Ergebnis eigentlich zufrieden.";
        SetFlag(F_PLATFORM_DUG);
        give Podest general;
        give Eisenplatte ~concealed;
        "Stück um Stück befreist du das Podest von dem großen Sandhaufen, während dir der Wind unerbittlich ins Gesicht peitscht.^^Direkt unter dem Galgen wird eine stabile Holzplatte sichtbar, die gewissenhaft mit vielen großen Nägeln auf dem Podest festgenagelt wurde.";
    }
    ! Brecheisen + Eisenplatte/Podest (pry open hatch)
    if ((noun == Brecheisen && (second == Eisenplatte || second == Podest)) ||
        ((noun == Eisenplatte || noun == Podest) && second == Brecheisen)) {
        if (Brecheisen notin player) "Du hast das Brecheisen nicht dabei.";
        if (FlagIsClear(F_PLATFORM_DUG)) "Du musst zuerst den Sand wegschaufeln.";
        if (FlagIsSet(F_PLATFORM_OPEN)) "Die Falltür ist bereits geöffnet.";
        SetFlag(F_PLATFORM_OPEN);
        give Podest open;
        give Seil ~concealed;
        "Du hebelst einen Nagel nach dem anderen aus der Platte heraus, nicht ohne gelegentlich einen Fluch auszustoßen und dich lautstark zu fragen, was zur Hölle du hier eigentlich machst.^^Etwa eine halbe Stunde und einen abgebrochenen Fingernagel später hast du alle Nägel erfolgreich entfernt. Schweißgebadet schiebst du die Holzplatte beiseite und legst eine quadratische, dunkle Öffnung frei.";
    }
    ! Brecheisen + Spalt (widen crevice)
    if ((noun == Brecheisen && second == Spalt) ||
        (noun == Spalt && second == Brecheisen)) {
        if (Brecheisen notin player) "Du hast das Brecheisen nicht dabei.";
        if (player notin r_Huegelkette) "Hier ist kein Spalt.";
        if (FlagIsClear(F_BOULDER_DISCOVERED)) "Du siehst hier keinen Spalt.";
        if (FlagIsSet(F_BOULDER_REMOVED)) "Der Brocken ist schon weg.";
        if (FlagIsSet(F_CREVICE_WIDENED)) "Du hast den Spalt bereits soweit aufgehebelt wie möglich.";
        SetFlag(F_CREVICE_WIDENED);
        ActivateTopic(Ladenmann, 351);
        "Du schiebst das flache, gerade Ende der Brechstange in den Spalt und hämmerst mit einem flachen Stein auf das gebogene Ende.^^Du klopfst und hebelst eine Weile bis endlich ein flaches, handbreites Stück Fels vom Brocken abbricht. Der Spalt ist nun deutlich breiter.^^Du steckst das Brecheisen wieder ein.";
    }
    ! Stange + Spalt (pry out boulder)
    if ((noun == Stange && second == Spalt) ||
        (noun == Spalt && second == Stange)) {
        if (Stange notin player) "Du hast die Metallstange nicht dabei.";
        if (player notin r_Huegelkette) "Hier ist kein Spalt.";
        if (FlagIsClear(F_CREVICE_WIDENED)) "Der Spalt ist zu eng für die Stange. Du musst ihn zuerst mit dem Brecheisen aufweiten.";
        if (FlagIsSet(F_BOULDER_REMOVED)) "Der Brocken ist schon weg.";
        SetFlag(F_BOULDER_REMOVED);
        move Stange to r_Huegelkette;
        give Stange scenery;
        print "Du schiebst die lange Metallstange langsam in den Spalt. Passt perfekt!^^Du packst die Stange mit beiden Händen am freien Ende und drückst sie kräftig Richtung Berg. Der Brocken scheint sich leicht zu bewegen. ~BRAAAK!~ krächzt Molly aufgeregt und lässt sich auf deiner Schulter nieder.^^Du blickst dich noch einmal um - es scheint niemand in Hörweite zu sein. Mit deinem ganzen Gewicht stemmst du dich erneut gegen die Stange, und siehe da - der Brocken löst sich!^^";
        style bold; print "RRRRRRRRRRRRRR..."; style roman;
        print "^^";
        doScreenbreak();
        style underline; print "Ihr seid schon ewig nicht mehr hier am Pier gewesen. Sie wollte das Geld wie immer sparen für später, aber heute wolltest du unbedingt mit ihr ans Meer.^^~Mit Hut oder ohne, was denkst du?~^^Claire sitzt auf einem Schemel und hält lachend den wild im Wind flatternden Hut fest. Du hast dem Zeichner zwei Dollar gegeben, hoffentlich wird das ein schönes Bild. Sein Kohlestück huscht hastig und geübt über das Papier.^^Möwen kreisen am Ende des Piers und kreischen laut auf, als ein kleiner Junge versucht sie zu fangen. Sie dreht den Kopf und lächelt dich an. Du ballst die Faust in der Tasche, den Ring dabei fest umklammernd.^"; style roman;
        print "^Wo bist du, Claire?^";
        print "^";
        doScreenbreak();
        move Papagei to r_Barbier;
        "Du öffnest die Augen.^^Offenbar hast du dir (wieder einmal) den Kopf gestoßen, diesmal wohl, als du dich vor dem losrollenden Felsbrocken mit einem Hechtsprung in Sicherheit bringen wollest. Zumindest das scheint funktioniert zu haben.^^Langsam rappelst du dich auf und klopfst dir den Staub von den Schultern. Was für ein Scheißtag.";
    }
    ! Seil + Spitzfelsen (tie rope)
    if ((noun == Seil && second == Spitzfelsen) ||
        (noun == Spitzfelsen && second == Seil)) {
        if (Seil notin player) "Du hast das Seil nicht dabei.";
        if (player notin r_Hoehle) "Hier gibt es nichts, woran du das Seil befestigen könntest.";
        if (FlagIsSet(F_ROPE_TIED)) "Das Seil ist bereits befestigt.";
        SetFlag(F_ROPE_TIED);
        give Seil scenery;
        "Du bindest das Seil um den Felsen und fixierst es mit einem ordentlichen Knoten.";
    }
    ! Revolver + VaultKeil (shoot wedge - explosion)
    if ((noun == Revolver && second == VaultKeil) ||
        (noun == VaultKeil && second == Revolver)) {
        if (Revolver notin player && (Tasche notin player || Revolver notin Tasche)) "Du hast den Revolver nicht dabei.";
        if (player notin r_Gewoelbe) "Das macht hier keinen Sinn.";
        if (FlagIsClear(F_LUCY_FREE)) "Das würde alle gefährden. Kümmere dich zuerst um die Wache und hol Lucy raus.";
        if (FlagIsClear(F_VAULT_SHOWDOWN)) "Vorsicht - fang hier nicht einfach an zu schießen. Warte auf den richtigen Moment.";
        print "Du kneifst das linke Auge zu und zielst sorgfältig über Kimme und Korn auf den Holzkeil, der den Karren an seinem Platz hält. Du atmest zur Hälfte aus und drückst ab.^^";
        print "Der Schuss löst sich perfekt und lässt den getroffenen Holzkeil in hohem Bogen davonschnellen. Durch die entstandene Staubwolke hindurch setzt sich der Karren laut rumpelnd in Bewegung und rollt genau auf euch zu.^^";
        print "Die Männer halten inne und drehen sich um, die Augen vor Angst geweitet.^^";
        print "'Das Nitro! RAUS HIER!'^^";
        print "Du drehst dich zu Michael und Lucy um, die mit starrem Blick an dir vorbeisehen, die Münder weit geöffnet. Du hechtest auf sie und drückst sie zu Boden, kurz bevor die Welt um dich explodiert.";
        doWhiteLight();
        move Michael to r_Sheriff;
        move Lucy to r_Sheriff;
        give Michael concealed;    ! room desc mentions them; don't auto-list
        give Lucy concealed;       ! (Lucy was already concealed; keep it)
        SetFlag(F_ENDING_ACTIVE);
        SetFlag(F_PLAYER_LOCKED_UP);
        Sheriff.talk_array = talk_array_sheriff_ende;
        give r_Sheriff ~visited;
        PlayerTo(r_Sheriff, false);
        rtrue;
    }
    ! Revolver + Maenner/VaultThompson/anything in Gewoelbe during showdown = death
    if (player in r_Gewoelbe && FlagIsSet(F_VAULT_SHOWDOWN)) {
        if ((noun == Revolver && second == VaultKarren) || (noun == VaultKarren && second == Revolver)) {
            print "Blitzschnell ziehst du den Revolver und schießt auf den Karren.^^Der Karren wackelt leicht, kippt aber nicht um.^^Ein Gewehrkolben trifft dich brutal an der Stirn als dich die Männer erreichen und überwältigen.";
            doVaultDeath();
            rtrue;
        }
        if ((noun == Revolver || second == Revolver) && noun ~= VaultKeil && second ~= VaultKeil && noun ~= VaultKarren && second ~= VaultKarren) {
            print "Du reißt den Revolver hoch und triffst zwei der heranstürmenden Männer in Brust und Bauch, ehe dir eine Kugel das Knie zerfetzt. Schreiend sinkst du zu Boden.";
            doVaultDeath();
            rtrue;
        }
        if ((noun == Brecheisen || noun == Schaufel || second == Brecheisen || second == Schaufel) &&
            (noun == Maenner || second == Maenner || noun == VaultThompson || second == VaultThompson)) {
            print "Du holst mit dem Werkzeug aus, kurz bevor dir ein anderer mit einem gezielten Schuss das Licht ausbläst.";
            doVaultDeath();
            rtrue;
        }
    }
    ! Revolver + Geselle (shoot crouching guard = death in vault)
    if ((noun == Revolver && second == Geselle) ||
        (noun == Geselle && second == Revolver)) {
        if (player notin r_Gewoelbe) rfalse;
        if (Geselle has concealed && FlagIsSet(F_GUARD_OUT)) "Der braucht erstmal keinen weiteren Schuss.";
        if (Geselle hasnt general) "Keine gute Idee. Ein Schuss würde die ganze Höhle alarmieren.";
        ! Handle same as non-Revolver attack (crouching)
        print "BAUZ! Du streckst den Mann mit einem gezielten Schlag mit dem Revolver nieder.^^Du siehst dich verstohlen um, aber keiner der Arbeiter scheint etwas gehört zu haben. Du steckst das leuchtende Taschentuch schnell wieder ein.^";
        give Geselle concealed;
        give Geselle ~general;
        give Taschentuch ~ablegbar;
        SetFlag(F_GUARD_OUT);
        ActivateTopic(Lucy, 400);
    }
    ! Brecheisen/Schaufel + Geselle (knock out crouching guard)
    if ((noun == Brecheisen || noun == Schaufel) && second == Geselle) {
        if (player notin r_Gewoelbe) rfalse;
        <<UseTogether Geselle noun>>;
        rtrue;
    }
    ! Fallback
    "Ich weiß nicht, wie man das benutzt.";
];

[InfoSub;
    print "Lenke deinen Charakter durch Richtungsangaben wie ";
    style bold; print "SÜD"; style roman; print " (oder kürzer: S), ";
    style bold; print "NORDWEST"; style roman; print " (NW), ";
    style bold; print "RUNTER"; style roman; print " (R), ";
    style bold; print "RAUS"; style roman; print " etc. sowie folgende Anweisungen:
^
^- "; style bold; print "SCHAU"; style roman; print " (L)
^- "; style bold; print "UNTERSUCHE"; style roman; print " <Sache> (U)
^- "; style bold; print "NIMM"; style roman; print " <Sache> (P)
^- "; style bold; print "REDE MIT"; style roman; print " <Person> (T)
^- "; style bold; print "BENUTZE"; style roman; print " <Sache> ";
    style bold; print "MIT"; style roman; print " <Sache> (B) - "; 
    style bold; print "LEGE"; style roman; print " / ";
    style bold; print "DRÜCKE"; style roman; print " / ";
    style bold; print "ÖFFNE"; style roman; print " <Sache>
^
^Andere Anweisungen sind ebenfalls möglich. Ein typischer Anfang wäre z.B. ";
    style bold; print "SCHAU"; style roman; print ", ";
    style bold; print "ÖFFNE FENSTER"; style roman; print ", ";
    style bold; print "UNTERSUCHE NACHTTISCH"; style roman; print ", ";
    style bold; print "NIMM TASCHE"; style roman; print ", ";
    style bold; print "RUNTER"; style roman; print ", ";
    style bold; print "REDE MIT FRAU"; style roman;
    print " und so weiter.^^Mit "; style bold; print "LAUF"; style roman;
    print " werden die bereits besuchten Orte angezeigt. Diese können mit ";
    style bold; print "LAUF"; style roman; print " <Ort> direkt erreicht werden. ";
    style bold; print "INV"; style roman; print " (I) zeigt dein Inventar, also was du bei dir trägst. ";
    style bold; print "SPEICHERN"; style roman; print " und ";
    style bold; print "LADEN"; style roman; print " ist ebenfalls möglich. Mit ";
    style bold; print "TIPP"; style roman; print " bekommst Du einen Hinweis, wie es weiter geht.^";
    new_line;
    print "Aktionen wie das Betreten neuer Räume oder der Fund von Gegenständen schalten oft neue Dialogoptionen frei, es ist daher sinnvoll, mehrmals mit Personen zu sprechen. Unter https://ikeserver.de/Staub gibt es weitere Hinweise und eine Komplettlösung, wenn's mal nicht weiter geht.^";
];

[CreditsSub;
    print "Vielen Dank an Olaf Nowacki, Hannes Schüller, Michael L. und meine Familie für ihr hilfreiches Feedback sowie den GerX-/deform-Autoren für die deutsche Inform-Erweiterung. Das Cover wurde mit Hilfe von Stable Diffusion XL erstellt.^";
];

[HintSub;
    if (r_Saloon hasnt visited) { "Gehe raus."; }
    if (player hasnt Tasche && FlagIsClear(F_PLAYER_LOCKED_UP)) { "Nimm deine Tasche mit."; }
    if (FlagIsClear(F_SALOON_GOT_COFFEE) && r_Saloon has visited) { "Rede mit der Frau im Saloon."; }
    if (r_Hauptstrasse hasnt visited) { "Gehe RAUS durch die Schwingtür."; }
    if (FlagIsSet(F_PLAYER_LOCKED_UP)) { "Rede mit dem Sheriff."; }
    if (r_Sheriff has visited && FlagIsClear(F_PLAYER_LOCKED_UP)) {
        if (r_Mine hasnt visited) { "Erkunde die Stadt. Gehe zur Ranch im Westen."; }
        if (Taschentuch in r_Mine) { "Gehe zur Mine westlich der Ranch und schau dich um."; }
        if (Taschentuch in player && r_Laden hasnt visited) { "Rede mit der Barfrau und erkunde die Läden."; }
    }
    "Sieh dich genauer um.";
];

[Initialise;
    lookmode = 2;
    notify_mode = false;
    inventory_style = 0;
    told_count->TC_BARBIER_MOLLY = 0; ! seeded to 1 in mart_r363 when pg-Barbier-molly2 activates
    print "squieeeek ...^squieeek ...^squieeeeek ...^^Langsam wachst du auf.^^Dein Kopf dröhnt erbarmungslos und das Blut pulsiert schmerzhaft in deinen Schläfen.^";
];

[sayPageTold index count;
    count = told_count->index;
    count++;
    told_count->index = count;
    if (count > 7) {
        print " Das hab' ich dir ";
        style bold; print "VIEL ZU VIELE MALE"; style roman;
        print " gesagt!";
    } else if (count > 5) {
        print " Das hab' ich dir schon viele, ";
        style underline; print "VIELE MALE"; style roman;
        print " gesagt!";
    } else if (count >= 3) {
        print " Das habe ich dir doch schon ";
        switch (count) {
            3: print "dreimal";
            4: print "viermal";
            5: print "fünfmal";
        }
        print " ";
        switch (random(3)) {
            1: print "gesagt";
            2: print "erzählt";
            3: print "mitgeteilt";
        }
        print "!";
    } else if (count == 2) {
        print " Das habe ich dir doch schon gesagt!";
    }
];

Class Room
    with visitcounter 0;

Room r_Backstage;

! Cheap Scenery IDs
Constant CS_FENSTER 110;
Constant CS_BETT    111;

Room r_Zimmer "Zimmer"
    with name 'zimmer',
        description [;
            if (self has visited) {
                print "Dieses Zimmer ist ziemlich spärlich eingerichtet. In der Ecke steht ein Bett mit einem kleinen Nachttisch. An der gegenüberliegenden Wand befindet sich ein Fenster. Eine einfache Holztür führt nach draußen und die Treppe hinunter.^";
            } else {
                print "Du hustest zweimal kräftig und raffst dich schließlich langsam von dem staubigen Dielenboden hoch.^^";
                print "Dieses Zimmer ist ziemlich spärlich eingerichtet. In der Ecke steht ein Bett mit einem kleinen Nachttisch. An der gegenüberliegenden Wand befindet sich ein Fenster. Eine einfache Holztür führt nach draußen und die Treppe hinunter.^^";
                print "Bitte gib jetzt "; style bold; print "INFO"; style roman;
                print " ein für einige grundlegende Informationen zum Spiel, vor allem wenn du noch nie ein Textadventure gespielt hast.^";
                give self visited;
            }
        ],
        cheap_scenery CS_ADD_LIST r_Zimmer (sc1),
        sc1
            CS_BETT 2 'bett' 'ecke' "Ein karges Bett, auf dem eine fleckige dünne Matratze liegt."
            1 'matratze' "Matratze ist ein ziemlich großes Wort für diese beiden grob zusammengenähten Stoffbahnen. Einzelne Strohhalme drücken sich überall durch die Nähte und Löcher im Stoff."
            CS_FENSTER 2 'fenster' 'scheibe' "Fahles Licht dringt durch die staubige Glasscheibe des Fensters. Draußen glaubst du ein Windrad zu erkennen."
            4 'windrad' 'rad' 'mast' 'windmühle' "Ein großes Windrad aus Metall dreht sich rhythmisch quietschend im Wind. Das Geräusch ist gerade nur schwer zu ertragen."
            1 'treppe' "Die Tür steht offen, du kannst einfach RAUS gehen."
            2 'wand' 'putz' "Wand und Decke mögen einmal weiß gewesen sein, aber inzwischen wird der graue und rissige Putz nur noch von gutem Willen aufrecht gehalten."
            2 'boden' 'dielen' "Einen Besen oder gar Wasser hat dieser Boden schon lange nicht mehr gesehen. An vielen Stellen scheint das Licht des darunter liegenden Raumes durch die Dielen.",
        d_to HolzTuer, out_to HolzTuer,
        before [;
            Smell:
                if (noun == player) rfalse;
                "Es riecht leicht nach Pisse, aber du hast schon an deutlich schlimmeren Orten geschlafen.";
            Enter, Open, Use:
                if (cs_match_id == CS_FENSTER) "Ist zugenagelt. Vielleicht hat hier der eine oder andere früher seine Zeche nicht bezahlt und ist so abgehauen.";
                if (cs_match_id == CS_BETT) "Du bist nicht müde. Nur kaputt.";
            Listen:
                print "squieeek ...^squieeek ...^squieeeeek ..."; new_line; rtrue;
            Go:
                if (selected_direction == n_to or s_to or e_to or w_to or
                    ne_to or nw_to or se_to or sw_to)
                    "Du könntest RAUS oder RUNTER gehen.";
        ],
    has neuter;

Object -> HolzTuer "Holztür"
    with name 'holztür' 'tür' 'scharniere',
        description "Eine Holztür mit grob gearbeiteten Scharnieren.",
        door_dir (d_to) (u_to),
        found_in r_Zimmer r_Saloon,
        before [;
            Close: "Du lässt sie lieber offen.";
            Open: "Die Tür steht offen, geh einfach RAUS.";
        ],
    has static scenery door open ~openable female;

Object -> Nachttisch "Nachttisch"
    with name 'nachttisch' 'fach' 'nachtisch' 'tisch',
        description "Ein kleiner Nachttisch mit einem offenen Fach.^",
        after [; Examine: <Search self>; ],
    has scenery open ~openable container;

Object -> -> Tasche "Umhängetasche"
    with name 'umhängetasche' 'tasche' 'zeug' 'sachen' 'kram',
        description [;
            if (self has open) "Eine abgewetzte Umhängetasche aus rissigem Leder.";
            else "Eine abgewetzte Umhängetasche aus rissigem Leder. Sie ist geschlossen.";
        ],
        after [;
            Take: setTalkOptionsBarfrauKaffee(); rfalse;
            Drop: setTalkOptionsBarfrauKaffee(); rfalse;
        ],
    has ~open openable container female;

[noDropValuable; "Du würdest das lieber behalten."; ];

Object -> -> -> Zeichnung "Zeichnung"
    with name 'zeichnung' 'bild' 'kohlezeichnung',
        description "Eine gefaltete Kohlezeichnung, an den Kanten schon leicht brüchig. Sie zeigt Claire, deine Frau.^^Sie fehlt dir so sehr.",
        before [;
            Drop: noDropValuable(); rtrue;
        ],
        after [;
            Take:
                if (self notin player) {
                    print "^Du steckst die Zeichnung behutsam in die Innenseite deiner Weste.^";
                    move self to player;
                }
            Examine:
                if (self notin player) {
                    print "^Du steckst die Zeichnung behutsam in die Innenseite deiner Weste.^";
                    move self to player;
                }
        ],
    has female;

Object -> -> -> Revolver "Revolver"
    with name 'revolver' 'colt' 'knarre' 'waffe' 'pistole' 'schiesseisen',
        description "Dein Colt Navy, Model 1861. Frisch geputzt, geladen und schussbereit.",
        before [;
            Drop: noDropValuable(); rtrue;
            Open: "Die Waffe ist einsatzbereit, das ist alles was du wissen musst.";
        ];

Object -> -> -> Einberufungsbescheid "Einberufungsbescheid"
    with name 'einberufungsbescheid' 'bescheid' 'papiere' 'brief' 'dokument',
        description "Ein Einberufungsbescheid für Thomas Marshall, laut Datum über fünf Jahre alt. Ein wichtiges Dokument, das du immer bei dir trägst, weist es dich doch als ehemaligen Armeeangehörigen aus. Außerdem kannst du deinen Namen nachschauen, wenn die Nacht mal wieder etwas heftig war.",
        before [;
            Drop: noDropValuable(); rtrue;
            Take:
                if (self in Tasche) "Du lässt die Papiere lieber in deiner Tasche.";
        ];

Global Geldbetrag = 12;

Object -> -> -> Geld "Geld"
    with name 'geld' 'dollar' 'scheine',
        article 0,
        description [; print "Etwa ", Geldbetrag, " Dollar.^"; ],
        before [;
            Drop: noDropValuable(); rtrue;
            Take:
                if (self in Tasche) "Du lässt das Geld lieber in deiner Tasche.";
        ],
    has neuter proper;

! --- FLAG CONSTANTS ---

Constant F_PLAYER_LOCKED_UP        = 32;
Constant F_SALOON_OFFERED_COFFEE   = 33;
Constant F_SALOON_GOT_COFFEE       = 34;
Constant F_BILLS_WIFE_FOUND        = 35;
Constant F_BILLS_WIFE_NAMED        = 36;
Constant F_PINCENEZ_FOUND          = 37;
Constant F_BOULDER_REMOVED         = 38;
Constant F_CREVICE_WIDENED         = 39;
Constant F_MOLLY_TRUSTING          = 40;
Constant F_MOLLY_TAKEABLE          = 41;
Constant F_MARTEN_KNOWN            = 42;
Constant F_ENDING_ACTIVE           = 43;
Constant F_BOULDER_DISCOVERED       = 44;
Constant F_ROPE_TIED                = 45;
Constant F_PLATFORM_DUG             = 46;
Constant F_PLATFORM_OPEN            = 47;
Constant F_GUARD_CROUCHING          = 48;
Constant F_GUARD_OUT                = 49;
Constant F_LUCY_FREE                = 50;
Constant F_LUCY_LISTENING           = 51;
Constant F_VAULT_SHOWDOWN           = 52;
Constant F_PLATFORM_KNOWN           = 53;

Constant TC_BARFRAU_KAFFEE   0;
Constant TC_LADENMANN_KNEIFER  1;
Constant TC_LADENMANN_STAB   2;
Constant TC_BARBIER_SCHAUFEL 3;
Constant TC_BARBIER_MOLLY    4;

Array told_count -> 5;

Global vault_death_count = 0;

[doScreenbreak;
    print "@@126@@126@@126^^";
];

[doWhiteLight;
    print "^--- WEISSES LICHT ---^";
];

[doVaultDeath _r;
    doWhiteLight();
    new_line;
    vault_death_count++;
    _r = random(3);
    print "Nein, so war es nicht gewesen. ";
    switch (_r) {
        1: print "Du lässt dir noch einmal alle Handlungsmöglichkeiten durch den Kopf gehen.";
        2: print "Du hast es irgendwie anders gemacht, da bist du dir sicher.";
        3: print "In Wirklichkeit war dir natürlich eine viel schlauere Lösung eingefallen.";
    }
    if (vault_death_count > 2)
        print "^^Vielleicht solltest du dich noch einmal genauer umschauen.";
    "^^Langsam lichtet sich der weiße Nebel vor deinen Augen. Die Männer stürmen immer noch auf euch zu.";
];

[endingCleanup;
    talk_menu_talking = false;
    move Taschentuch to r_Backstage;
    move Schaufel to r_Backstage;
    move Lampe to r_Backstage;
    move Brecheisen to r_Backstage;
    move Einberufungsbescheid to Tasche;
    move Streichhoelzer to Tasche;
    give Tasche ~open;
    ClearFlag(F_ENDING_ACTIVE);
    ClearFlag(F_PLAYER_LOCKED_UP);
    PlayerTo(r_Steppe);
];

! ============================================================
! --- 2: SALOON ---
! ============================================================

Constant CS_SALOON_BUEHNE = 120;
Constant CS_SALOON_TREPPE = 121;

[descSaloon;
    if (r_Saloon hasnt visited) {
        print "Du schlurfst die Treppe hinunter und massierst dabei deine schmerzende linke Schulter.^^";
    }
    print "Der Saloon besteht aus einigen runden Tischen mit Stühlen und einer kleinen Bühne. Daneben führt eine Treppe hoch in dein Zimmer. Gegenüber befindet sich ein langer Tresen. Zwei massive Balken verlaufen unter der Decke. Eine Schwingtür im Norden führt nach draußen.^^";
    print "Hinter der Bar steht ";
    if (Barfrau hasnt proper) print "eine Frau";
    else print (string) Barfrau.short_name;
    print " und ";
    print (string) random(
        "poliert Gläser mit einem mäßig sauber wirkenden Stofflappen",
        "wischt gelangweilt den Tresen",
        "sortiert die Getränke",
        "dreht sich eine Zigarette",
        "kratzt sich am Kinn",
        "schnäuzt in ihr Geschirrtuch",
        "reinigt die Spüle",
        "zieht an ihrer Zigarette");
    if (Barfrau hasnt proper && r_Saloon hasnt visited) print ". Sie wirft dir einen leicht amüsierten Blick zu";
    ".";
];

[descSalonTische;
    Examine:
        print "Einige runde Holztische.";
        if (r_Hauptstrasse hasnt visited) print " Zwei der Tische sind umgeworfen.";
        "";
    default: rfalse;
];

[descSalonBalken;
    Examine:
        print "Mächtige Holzbalken stützen die Decke des großen Raumes. An einem der Balken ist ein langer Nagel eingeschlagen, daran baumelt eine Petroleumlampe.";
    default: rfalse;
];

[descSalonNagel;
    Examine:
        "Ein langer, rostiger Nagel, tief in einen der Deckenbalken getrieben. Er wird wohl dort bleiben bis der Saloon zusammenbricht.";
    default:
        "Du kannst ihn nicht erreichen und willst ihn eigentlich auch gar nicht.";
];


Room r_Saloon "Saloon"
    with description descSaloon,
        cheap_scenery
            CS_ADD_LIST r_Saloon (sc1),
        sc1
            CS_SALOON_BUEHNE 2 'bühne' 'podest' "Eine schlichte Holzbühne, die schon als Kulisse fuer manche Schlaegerei gedient hat."
            2 'tisch' 'tische' descSalonTische
            CS_SALOON_TREPPE 2 'treppe' 'treppenhaus' "Die Treppe führt in dein gemietetes Zimmer. Die anderen Zimmer gehen dich nichts an."
            3 'balken' 'deckenbalken' 'decke' descSalonBalken
            1 'nagel' descSalonNagel
            ,
        u_to HolzTuer, in_to HolzTuer,
        n_to Schwingtuer, out_to Schwingtuer,
        before [;
            Smell: "Es riecht nach verschüttetem Bier und alten Zigaretten.";
            Go:
                if (player in Stuhl && selected_direction == d_to) {
                    steigAusStuhl(); rtrue;
                }
            Enter, Open, Use:
                if (cs_match_id == CS_SALOON_TREPPE) "Du kannst einfach die Treppe hochgehen.";
            Talk:
                if (player in Stuhl)
                    "Wenn du keine Rede halten willst, solltest du vielleicht erst vom Stuhl runtersteigen.";
        ];

Object -> Schwingtuer "Schwingtür"
    with name 'schwingtür' 'tuer' 'schwingtürchen',
        description "Halbhohe Schwingtür aus zwei Holzpaneelen.",
        door_dir (n_to) (s_to),
        door_to doorToSaloon,
        found_in r_Saloon r_Hauptstrasse,
    has static scenery door open ~openable female;

[doorToSaloon;
    if (self in r_Saloon) {
        if (Tasche notin player) {
            print "Du hast dein Zeug noch oben. Außerdem könntest du erst mal einen Kaffee gebrauchen.^"; rtrue;
        }
        return r_Hauptstrasse;
    }
    return r_Saloon;
];

Object -> Stuhl "Stuhl"
    with name 'stuhl' 'hocker' 'stühle' 'hocker',
        description descStuhl,
        before [;
            Take: "Die Stühle sind zu sperrig zum Mitnehmen.";
            Push, Pull: rueckeStuhl(); rtrue;
            Enter, Climb, Use: steigAufStuhl(); rtrue;
            GetOff, Exit: steigAufStuhl(); rtrue;
        ],
    has supporter concealed ~moved;

[descStuhl;
    print "Unauffällige Holzstühle, einige mit dünnen Brettern zusammengeflickt.";
    if (r_Hauptstrasse hasnt visited) {
        print " Einige von ihnen liegen zersplittert neben dem Eingang.^^";
        print (The) Barfrau;
        print " sagt: ~Wollte dich erst ausschlafen lassen, bevor ich hier aufräume.~";
    }
    "";
];

[rueckeStuhl;
    if (Stuhl has moved) {
        "Der Stuhl steht schon gut.";
    } else {
        print "Du stellst einen der Stühle unter den Deckenbalken mit der Laterne.^";
        give Stuhl moved;
    }
];

[steigAufStuhl;
    if (Stuhl hasnt moved) {
        "So wie die Stühle gerade stehen, siehst du dafür keinen Grund.";
    } else if (player notin Stuhl) {
        move player to Stuhl;
        print "Du steigst auf den Stuhl unter dem Balken.^";
        Look();
        rtrue;
    } else {
        move player to r_Saloon;
        print "Du steigst von dem Stuhl herunter.^";
        Look();
        rtrue;
    }
];

[steigAusStuhl;
    move player to r_Saloon;
    print "Du steigst von dem Stuhl herunter.^";
    Look();
    rtrue;
];

Object -> Lampe "Petroleumlampe"
    with name 'petroleumlampe' 'lampe' 'laterne' 'petroleum',
        description descLampe,
        before [;
            Take: nehmeLampe(); rtrue;
            SwitchOn: zuendeLampeAn(); rtrue;
            Drop: noDropValuable(); rtrue;
        ],
    has concealed ~on static;

[descLampe;
    if (Lampe in player) print "Eine große, gefüllte ";
    else print "Eine große ";
    print "Petroleumlampe mit Henkelgriff. ";
    if (Lampe hasnt on) "Sie ist aus.";
    "Sie ist angezündet.";
];

[nehmeLampe;
    if (Lampe in player) "Du hast sie doch schon!";
    if (Lampe has static) ActivateTopic(Barfrau, 309);
    if (Stuhl hasnt moved) "Du kommst so nicht ganz ran, die Lampe hängt etwas zu hoch.";
    if (Lampe has static) {
        print_ret (The) Barfrau, " zieht eine Augenbraue hoch. ~Was genau soll das werden?~";
    }
    if (player notin Stuhl) "Wenn du auf den Stuhl steigst, kannst du die Lampe jetzt wohl erreichen.";
    move Lampe to player;
    ActivateTopic(Barfrau, 310);
    InactivateTopic(Ladenmann, 351);
    ActivateTopic(Ladenmann, 353);
    "Du nimmst die Lampe vom Nagel.";
];

[zuendeLampeAn;
    if (Lampe has on) "Die Lampe brennt schon.";
    if (Lampe notin player) "Du musst die Lampe bei dir tragen.";
    if (Streichhoelzer notin player) {
        ActivateTopic(Barfrau, 310);
        ActivateTopic(Ladenmann, 353);
        "Du hast nichts, um die Lampe anzuzünden.";
    }
    give Lampe on;
    "Du nimmst eines der Schwefelhölzer und reißt es an deinem schartigen Daumennagel an. Behutsam hältst du es an den Docht der Lampe. Ein behagliches Licht breitet sich aus.";
];

Object Streichhoelzer "Streichhölzer" r_Backstage
    with name 'streichhölzer' 'zündhölzer' 'hoelzer' 'tuetchen' 'papiertuetchen',
        description "Eine ganze Menge Streichhölzer in einem braunen Papiertütchen.",
        before [;
            Drop: noDropValuable(); rtrue;
        ],
    has concealed pluralname;

Object Kaffeetasse "Kaffeetasse" r_Backstage
    with name 'kaffeetasse' 'tasse' 'becher' 'kaffee',
        description descKaffeetasse,
        filled 100,
        before [;
            Drink: trinkKaffee(); rtrue;
            Take:
                print (The) Barfrau;
                print " hebt eine Augenbraue. ~Die Tasse bleibt hier!~^"; rtrue;
        ],
    has female;

[descKaffeetasse;
    print "Eine leicht ramponierte Kaffeetasse";
    if (Kaffeetasse.filled == 100) " mit starkem schwarzen Kaffee darin.";
    ". Sie ist leer.";
];

[trinkKaffee;
    if (Kaffeetasse.filled == 100) {
        Kaffeetasse.filled = 70;
        "Du nimmst einen kleinen Schluck. Nicht übel.";
    }
    if (Kaffeetasse.filled == 70) {
        Kaffeetasse.filled = 30;
        "Du nimmst noch einen Schluck. Du fühlst dich schon deutlich besser.";
    }
    if (Kaffeetasse.filled == 30) {
        Kaffeetasse.filled = 0;
        "Du trinkst deinen Kaffee aus.";
    }
    "Die Tasse ist leer.";
];

Object Keks "Keks" r_Backstage
    with name 'keks' 'plätzchen',
        description "Ein Keks.",
        before [;
            Eat: "Den hebst du lieber auf.";
            Take:
                move Keks to player;
                "Du packst den Keks vorsichtig ein.";
            Give:
                if (second == Papagei) {
                    print "Molly schnappt gierig nach dem Keks und mümmelt ihn ruck-zuck herunter.^";
                    SetFlag(F_MOLLY_TRUSTING);
                    remove Keks;
                    rtrue;
                }
        ];

[descTresen;
    "Der Tresen hat einige dunkle Stellen und kleinere Schnitzspuren gelangweilter Gäste, sieht aber insgesamt recht sauber aus.";
];

Object Tresen "Tresen" r_Saloon
    with name 'tresen' 'theke' 'holztheke',
        description descTresen,
    has supporter scenery;

Object -> Barfrau
    with name 'barfrau' 'frau' 'ella' 'bardame',
        short_name "Frau",
        description descBarfrau,
        talk_array talk_array_barfrau,
        before [;
            Ask, AskFor, AskTo, Tell, Give, Show: "Sag einfach REDE MIT ihr.";
        ],
    has animate female concealed;

[descBarfrau;
    if (Barfrau hasnt proper) {
        print "Die Frau hinter dem Tresen heißt Ella, ihr kennt euch noch von früher. ";
        give Barfrau general;
        Barfrau.short_name = "Ella";
        give Barfrau proper;
    }
    print "Sie ist ungefähr Ende vierzig, eine korpulente, attraktive Frau mit Lachfalten und schwieligen Händen. Sie hat ein dunkelrotes Stofftuch um die Stirn gebunden und ";
    print (string) random(
        "poliert Gläser mit einem mäßig sauber wirkenden Stofflappen",
        "reinigt die Spüle",
        "zieht an ihrer Zigarette");
    ".";
];

[setTalkOptionsBarfrauKaffee;
    if (FlagIsSet(F_SALOON_OFFERED_COFFEE)) {
        if (Tasche in player) {
            InactivateTopic(Barfrau, 302);
            ActivateTopic(Barfrau, 303);
        } else {
            InactivateTopic(Barfrau, 303);
            ActivateTopic(Barfrau, 302);
        }
    }
];

[gibKaffee;
    ClearFlag(F_SALOON_OFFERED_COFFEE);
    SetFlag(F_SALOON_GOT_COFFEE);
    move Kaffeetasse to Tresen;
    move Keks to Tresen;
];

[ellaGibtLampeErfrei;
    give Lampe ~static;
];

[bf_r300; if (Barfrau hasnt general) print "Die Frau hinter dem Tresen heißt Ella, ihr kennt euch noch von früher.^^"; print "~Mir geht's ganz gut, danke. So leicht bringt mich hier nichts mehr aus der Fassung, so 'ne kleine Kneipenschlägerei jedenfalls nicht.~"; ];
[bf_r301;
    SetFlag(F_SALOON_OFFERED_COFFEE);
    ActivateTopic(Barfrau, 302);
    setTalkOptionsBarfrauKaffee();
    print "~Ist gestern noch hoch hergegangen hier, als du schon oben warst. Ich räume das später auf.~, sagt ";
    print (string) Barfrau.short_name;
    print ". ~Du siehst ganz schön fertig aus, willst du einen Kaffee? Hab' direkt einen aufgebrüht, als ich dich hab' aufstehen hören.~";
];
[bf_r302; print "~Hast dein Zeug oben gelassen? Ohne Tasche hast du doch gar kein Geld dabei."; sayPageTold(TC_BARFRAU_KAFFEE); print "~"; ];
[bf_r303; print (string) Barfrau.short_name; print " dreht sich um und gießt eine tiefschwarze dampfende Brühe aus einem kleinen Blechtopf in eine Tasse und stellt sie vor dir auf den Tresen.^^~Wohl bekomm's, macht 'nen Vierteldollar. Zucker ist leider aus, aber 'n Keks hab' ich noch.~^^"; print (string) Barfrau.short_name; print " legt einen Keks neben die Tasse. Du legst das Geld hin, steckst die Nase tief in die Tasse und atmest einmal tief ein. Herrlich."; ];
[bf_r304; print "~Keine Ahnung wer diesmal angefangen hat. Die Mifflin-Brüder haben mal wieder ordentlich gesoffen und mit ihren Scheinen gewedelt, aber natürlich nichts springen lassen.~^^"; print (string) Barfrau.short_name; print " zuckt mit den Schultern und lächelt. ~Denke das wird einigen nicht gefallen haben.~"; ];
[bf_r306; print "~Lucy? Wieso?~^^Du erzählst "; print (string) Barfrau.short_name; print " kurz, was passiert ist.^^~Verdammter Mist. Lucy hab' ich zuletzt vor ein paar Tagen gesehen, aber Michael war gestern hier. Hab' ihn mit ein paar Leuten aus der Mine tuscheln sehen, dann weiß ich nicht mehr. Ist bestimmt vor der Schlägerei abgehauen, ist ja nicht so sein Ding.~"; ];
[bf_r307; print "Du zeigst "; print (string) Barfrau.short_name; print " das Taschentuch mit dem Monogramm.^^~Ja, das gehört bestimmt ihr. Wo hast du das gefunden?~"; ];
[bf_r308; if (Barfrau has proper) print "Ellas"; else print "Ihr"; print " Gesicht verdunkelt sich.^^~Das gefällt mir gar nicht. Sie würde niemals freiwillig in die Mine gehen, sie hatte schon als Kind Angst davor.~^^Sie zieht nervös an ihrer Zigarette und blickt dir fest in die Augen.^^~Tom, du musst da rein. Ich glaube, der Eingang ist zu gut bewacht. Es gab mal einen Stollen im Süden, aber der wurde vor einigen Jahren von einem Haufen Geröll begraben.~"; ];
[bf_r309; if (FlagIsSet(F_BOULDER_REMOVED)) { print "Du erzählst "; print (string) Barfrau.short_name; print " kurz von dem Stolleneingang, den du freigelegt hast. Sie lächelt und nickt.^^"; } print "~Kannst die Lampe gerne mitnehmen, aber bis heute Abend will ich sie zurück!~"; ];
[bf_r310; print (string) Barfrau.short_name; print " runzelt die Stirn. ~Meine Zündhölzer sind fast alle, und ohne Feuer raucht sich's schlecht.~^^Sie pustet eine beeindruckende Rauchwolke über dich hinweg und deutet zur Tür. ~Bill hat bestimmt noch welche, kannst mir gerne welche mitbringen.~"; ];
[bf_r311; print (string) Barfrau.short_name; print " schüttelt den Kopf. ~Nee Tom, seit dem Rodeo-Vorfall neulich sind Seile bei mir verboten.~^^Sie grinst schelmisch. ~Frag' doch mal den alten Bill.~"; ];

Array talk_array_barfrau -->
    TM_ACTIVE 300 "~Alles klar bei dir?~"
        TM_NO_LINE
        bf_r300
        ellaEnthuelleNamen 304
    TM_ACTIVE 301 "~Sieht ja wild aus hier.~"
        TM_NO_LINE
        bf_r301
    TM_INACTIVE 302 "~Ich habe leider kein Geld dabei.~"
        TM_NO_LINE
        bf_r302
    TM_INACTIVE 303 "~Einen Kaffee bitte.~"
        TM_NO_LINE
        bf_r303
        gibKaffee
    TM_INACTIVE 304 "~Es gab 'ne Schlägerei?~"
        TM_NO_LINE
        bf_r304
        305
    TM_INACTIVE 305 "~Mifflin? Sagt mir nichts.~"
        TM_NO_LINE
        "~Ach du kennst die Mifflin-Brüder gar nicht? Dann sind die damals wohl erst aufgetaucht, als du schon aus der Stadt warst. Calvin und Bob heißen die, haben die alte Mine drüben im Westen wieder in Betrieb genommen und offenbar tatsächlich wieder was gefunden.~^^Ella hält kurz inne und zieht einmal kräftig an ihrer Zigarette.^^~Jedenfalls haben sie offenbar genug Kohle, um sich hier regelmäßig volllaufen zu lassen. Mir soll's recht sein.~"
    TM_INACTIVE 306 "~Hast du Lucy gesehen?~"
        TM_NO_LINE
        bf_r306
    TM_INACTIVE 307 "~Ich glaube, ich habe Lucys Taschentuch gefunden.~"
        TM_NO_LINE
        bf_r307
        308
    TM_INACTIVE 308 "~Vor der Mine westlich von hier.~"
        TM_NO_LINE
        bf_r308
    TM_INACTIVE 309 "~Kann ich die Lampe da haben?~"
        TM_NO_LINE
        bf_r309
        ellaGibtLampeErfrei
    TM_INACTIVE 310 "~Hast du auch etwas, womit ich die Lampe anzünden kann?~"
        TM_NO_LINE
        bf_r310
    TM_INACTIVE 311 "~Ich muss in die Mine. Hast du ein Seil?~"
        TM_NO_LINE
        bf_r311
    TM_END;

[ellaEnthuelleNamen;
    Barfrau.short_name = "Ella";
    give Barfrau proper;
    give Barfrau general;
];


Constant CS_SUN = 130;

[descHauptstrasse;
    r_Hauptstrasse.visitcounter++;
    if (r_Hauptstrasse hasnt visited) {
        print "Du trittst durch die Schwingtür vor den Saloon. Ein kleines Vordach schützt dich vor der sengenden Sonne. Ein unangenehm heißer Wind trägt einen dornigen Steppenläufer langsam aus der Stadt hinaus. Es ist kein Mensch zu sehen.^^";
    }
    print "Die breite, staubige Straße verläuft von Osten nach Westen. ";
    descGebaeude();
    print "Im Süden geht es in den Saloon.^";
    if (r_Hauptstrasse.visitcounter == 2 && Lucy in r_Ranch) {
        "^Als der Wind für einen Moment nachlässt, glaubst du ein leises Wimmern aus dem Westen zu hören.";
    } else if (r_Hauptstrasse.visitcounter == 5) {
        "^Eine Katze trabt gemächlich an dir vorbei, wirft dir einen müden Blick zu und verschwindet im Schatten zwischen den Häusern.";
    } else if (r_Hauptstrasse.visitcounter == 9) {
        "^Ein Geier setzt sich auf den Dachgiebel vor dir und betrachtet dich argwöhnisch, bevor er wieder davonfliegt.";
    } else if (r_Hauptstrasse.visitcounter == 13) {
        "^Ein Fensterladen fliegt mit lautem Getöse auf und eine Bettdecke wird von zwei dicken Armen kraftvoll ausgeschüttelt. Dann verschwindet die Decke in einer beeindruckenden Staubwolke und das Fenster wird krachend wieder zugeschlagen.";
    }
];

[descGebaeude;
    if (Gebaeude.examined) {
        print "Im Nordwesten liegt das Büro des Sheriffs, im Norden der Gemischtwarenladen und im Nordosten der Barbier. ";
    } else {
        print "Drei ähnlich aussehende Gebäude aus Holz liegen auf der gegenüberliegenden Straßenseite im Norden. ";
    }
    rtrue;
];

Room r_Hauptstrasse "Main Street"
    with name 'strasse' 'hauptstraße' 'platz',
        description descHauptstrasse,
        cheap_scenery
            CS_ADD_LIST r_Hauptstrasse (sc1)
            CS_ADD_LIST r_Hauptstrasse (sc2),
        sc1
            1 'vordach' "Ein kleines Vordach schützt dich vor der sengenden Sonne."
            CS_SUN 1 'sonne' "In die Sonne zu schauen ist schon unter normalen Umständen nicht sonderlich schlau, aber mit deinem Brummschädel erst recht nicht."
            3 'steppenläufer' 'wüstenläufer' 'dornbusch' "Der Steppenläufer ist bereits nicht mehr zu erkennen. Andere werden kommen und seinen Platz einnehmen."
            2 'büro' 'sheriffbüro' "Das Büro von Sheriff Dunder ist gleichzeitig auch seine Wohnung. Eine Katze liegt faul in dem langsam kürzer werdenden Schatten neben dem Haus."
            2 'gemischtwarenladen' 'laden' "Über dem Gemischtwarenladen hängt ein Schild mit der Aufschrift 'Bills Waren & Mehr'. Du fragst dich, was das Mehr als Waren sein könnte.",
        sc2
            2 'barbier' 'friseur' "Das Barbiergeschäft ist durch eine kleine rot-weiß-blaue Säule neben der Tür gekennzeichnet."
            2 'säule' 'stange' "Wenn der Wind stark genug bläst, dreht sie sich sogar ein bisschen."
            1 'katze' "Sie schaut dich nicht einmal an."
            3 'geier' 'vogel' 'decke' "Nichts mehr zu sehen."
            2 'staubwolke' 'wolke' "Längst verflogen.",
        s_to Schwingtuer, in_to Schwingtuer,
        nw_to SheriffTuer,
        n_to LadenTuer,
        ne_to r_Barbier,
        w_to r_Ranch,
        e_to r_Galgen,
        before [;
            Smell: "In der heißen und staubigen Vormittagsluft vermischen sich viele nicht näher identifizierbare Gerüche - die meisten davon nicht sehr angenehm.";
            Take:
                if (cs_match_id == CS_SUN) "Du nimmst die Sonne und steckst sie in die Tasche.^^.^.^.^^Wird langsam ein bisschen warm. Du stellst die Sonne schnell zurück.";
            Go:
                if (selected_direction == ne_to) {
                    if (FlagIsClear(F_PLAYER_LOCKED_UP) && r_Barbier hasnt visited) {
                        ! First time accessing barbier - no lock check here, door handled in room
                    }
                    if (FlagIsSet(F_PLAYER_LOCKED_UP))
                        "Die Eingangstür des Barbiergeschäfts ist verschlossen.";
                    if (r_Sheriff hasnt visited)
                        "Das Barbiergeschäft scheint noch geschlossen zu sein.";
                }
        ],
    has female;

Object -> Gebaeude "Gebäude"
    with name 'gebäude' 'häuser' 'haus' 'strasse' 'strassenseite',
        description "Das Gebäude im Nordwesten ist offenbar das Büro des Sheriffs. Im Norden befindet sich ein Gemischtwarenladen und daneben im Nordosten hat ein Barbier sein kleines Geschäft.",
        examined 0,
        before [;
            Examine: self.examined = true; rfalse;
        ],
    has scenery;

Object -> SheriffTuer "Bürotür des Sheriffs"
    with name 'sheriffbüro' 'büro' 'tuer' 'eingangstür',
        description "Die Eingangstür zum Büro des Sheriffs.",
        door_dir (nw_to) (se_to),
        found_in r_Hauptstrasse r_Sheriff,
        before [;
            Open:
                if (self has locked) "Die Eingangstür zum Büro des Sheriffs ist verschlossen.";
        ],
    has static scenery door ~open ~openable locked female;

Object -> LadenTuer "Ladentür"
    with name 'ladeneingang' 'ladentüre' 'ladentür' 'türe',
        description "Die Eingangstür zum Laden.",
        door_dir (n_to) (s_to),
        found_in r_Hauptstrasse r_Laden,
        before [;
            Open:
                if (self has locked) "Bills Gemischtwarenladen hat noch nicht geöffnet.";
        ],
    has static scenery door ~open ~openable locked female;

! ============================================================
! --- 4: SHERIFF ---
! ============================================================

Constant CS_SHERIFF_PRITSCHEN = 140;
Constant CS_SHERIFF_DURCHGANG = 141;
Constant CS_SHERIFF_HAUS      = 142;

[descSheriff;
    if (FlagIsSet(F_ENDING_ACTIVE)) {
        print "Du liegst auf einer der Pritschen im Büro des Sheriffs. In der Ecke sitzen Michael und Lucy, der junge Mann trägt einen leicht blutigen Verband um den Kopf. Sheriff Dunder sitzt hinter seinem Schreibtisch.^"; return;
    }
    print "Dies ist Sheriff Dunders Büro. ";
    if (FlagIsSet(F_PLAYER_LOCKED_UP))
        print "Du stehst vor einer der beiden Pritschen die an einer der Wände befestigt sind";
    else
        print "Zwei Pritschen sind an der Wand befestigt";
    print ".^^Auf der gegenüberliegenden Seite steht ein massiver Schreibtisch";
    if (FlagIsClear(F_PLAYER_LOCKED_UP))
        print ", dahinter sitzt Sheriff Dunder. Er hat den Hut tief ins Gesicht gezogen und scheint vor sich hin zu dösen";
    print ". Ein Durchgang führt offenbar tiefer ins Haus hinein. Eine breite Tür im Süden führt nach draußen.^";
];

Room r_Sheriff "Büro des Sheriffs"
    with description descSheriff,
        cheap_scenery
            CS_ADD_LIST r_Sheriff (sc1)
            CS_ADD_LIST r_Sheriff (sc2),
        sc1
            CS_SHERIFF_PRITSCHEN 14 'pritsche' 'pritschen' 'bett' 'betten' "Einfache Holzpritschen zum Sitzen oder Liegen. Sie haben sicher schon einige Banditen und/oder Saufkomas gesehen und riechen unangenehm."
            2 'wand' 'wände' "Nichts Besonderes."
            CS_SHERIFF_DURCHGANG 3 'durchgang' 'gang' 'zellen' "Ein niedriger Durchgang der vermutlich zu Zellen und Dunders Privaträumen führt. Dunder lässt dich da nicht rein und du musst da auch nichts sehen.",
        sc2
            CS_SHERIFF_HAUS 1 'haus' "Du glaubst nicht, dass du mehr vom Haus sehen wirst."
            2 'schnauzer' 'bart' "Nichts Besonderes."
            2 'gesicht' 'falten' "Nichts Besonderes."
            2 'kleidung' 'klamotten' "Praktische Kleidung, wie sie hier fast alle tragen.",
        se_to SheriffTuer, out_to SheriffTuer,
        before [;
            Smell: "Es riecht leicht muffig und nach diversen Exkrementen von den Pritschen. Kein Ort wo man lange verweilen möchte.";
            Go:
                if (FlagIsSet(F_PLAYER_LOCKED_UP)) {
                    print "Der Sheriff knurrt missbilligend. ~Bleib hier, Junge! Erst erzählst du mir, was hier los ist.~^"; rtrue;
                }
                if (Tasche in Schreibtisch) {
                    print "Der Sheriff knurrt missbilligend. ~Nimm deinen Kram mit, Junge.~^"; rtrue;
                }
            Enter:
                if (cs_match_id == CS_SHERIFF_PRITSCHEN) "Du hast keine Lust mehr zu ruhen. Außerdem sind die Pritschen ziemlich eklig.";
                if (cs_match_id == CS_SHERIFF_DURCHGANG or CS_SHERIFF_HAUS) <<Examine noun>>;
        ];

Object Schreibtisch "Schreibtisch" r_Sheriff
    with name 'schreibtisch' 'tisch',
        description "Ein wuchtiger Schreibtisch aus dunklem Holz.",
    has supporter scenery;

Object Sheriff "Sheriff Dunder" r_Sheriff
    with name 'sheriff' 'dunder' 'mann',
        description "Sheriff Dunder ist ein hagerer Mann Ende fünfzig mit stechend grünen Augen und einem weißen Schnauzer. Tiefe Falten ziehen sich durch sein tiefbraun gebranntes Gesicht. Ein matter Messing-Stern ziert die Weste seiner ansonsten unauffälligen Kleidung.",
        talk_array talk_array_sheriff,
        react_before [;
            Take:
                if (noun == Einberufungsbescheid && FlagIsSet(F_ENDING_ACTIVE))
                    "~Ich gebe dir deine Papiere gleich, wenn du mir alles erzählt hast.~";
                if (noun == Tasche or Einberufungsbescheid && FlagIsSet(F_PLAYER_LOCKED_UP)) {
                    print "~Dein Kram kommt später. Erst erzählst du mir, was hier los ist.~^"; rtrue;
                }
        ],
    has animate proper concealed;

Object Stern "Stern" r_Sheriff
    with name 'stern' 'messing' 'sternchen' 'abzeichen',
        description "Ein einfacher Sheriffstern, wie ihn Sheriffs im ganzen Land tragen.",
    has scenery;

[sh_r320; print "~Was passiert ist? Das wollte ich eigentlich von dir wissen, Junge.~^^Sheriff Dunder geht einen Schritt zurück und lehnt sich an seinen Schreibtisch.^^~Deputy Miller hat dich auf der Ranch gefunden, mit'm Gesicht im Dreck und Blut am Kopf. Wollte dich da nicht in der Gluthitze verrecken lassen und hat dich her geschleift.~^^Ja richtig, die Ranch, "; if (Lucy hasnt proper) print "die junge Frau"; else print "Lucy"; print "... langsam fällt dir alles wieder ein."; ];
[sh_r321; print "Dunder runzelt die Stirn. ~Miller sagt die Ranch war leer, kein Michael, keine Lucy. Was war da los, Junge?~^^Du berichtest kurz von deinem Gespräch mit der jungen Frau. Der Sheriff beäugt dich kritisch und seufzt schließlich.^^~Lucy ist die Tochter von Bürgermeister Thompson. Wenn ihr was passiert sein sollte, hast nicht nur du ein Problem.~"; ];
[sh_r322; print "Der Sheriff kommt langsam auf dich zu und schiebt sein Gesicht vor deines, bis sich eure Nasenspitzen beinahe berühren. Sein Atem stinkt faulig und seine Augen blitzen dich unheilvoll an.^^~Du bist jetzt einen Tag hier und schon ist die Tochter des Bürgermeisters verschwunden. Ich hab' keine Ahnung, was genau du damit zu tun hast und ob deine Geschichte stimmt, aber ich rate dir dringend herauszufinden, wo sie ist.~"; ];
[sh_r324; print "Der Sheriff wendet sich von dir ab und nickt widerwillig. ~Deine Papiere bleiben hier und du verlässt nicht die Stadt. Die Kutsche heute ist eh schon durch und einen Gaul wirst du dir nicht leisten können.~^^Dunder kommt noch einmal näher und blickt dich durchdringend an.^^~"; if (Tasche in Schreibtisch) print "Dein Kram liegt auf dem Tisch. "; print "Wir behalten dich im Auge, Junge. Mach' keinen Blödsinn.~"; ];

Array talk_array_sheriff -->
    TM_ACTIVE 320 "~Was ist passiert? Wie komme ich hierher?~"
        TM_NO_LINE
        sh_r320
        321
    TM_INACTIVE 321 "~Was ist mit der jungen Frau?~"
        TM_NO_LINE
        sh_r321
        322
    TM_INACTIVE 322 "~Wieso ist das jetzt mein Problem?~"
        TM_NO_LINE
        sh_r322
        323 324
    TM_INACTIVE 323 "~Können Sie mir was zu Lucy sagen?~"
        TM_NO_LINE
        "~Sie ist die Tochter von Bürgermeister Thompson, die Stieftochter, um genau zu sein. Hat sich mit dem Stallburschen verlobt, passt Thompson gar nicht.~^^Dunder zieht geräuschvoll einen hoch und spuckt unter die Pritsche.^^~Ihre Mutter ist wohl vor einem Jahr oder so gestorben. Kannte sie aber nicht, bin selbst erst ein paar Monate hier.~"
    TM_INACTIVE 324 "~Kann ich jetzt gehen?~"
        TM_NO_LINE
        sh_r324
        sheriffRelease
    TM_INACTIVE 325 "~Ich glaube, ich habe Lucys Taschentuch gefunden!~"
        TM_NO_LINE
        "~Spannende Geschichte, Junge.~ Er schaut dich abfällig an.^^~Komm wieder, wenn du sie gefunden hast, und nerv mich nicht mehr.~"
    TM_END;

[sheriffRelease;
    ClearFlag(F_PLAYER_LOCKED_UP);
    give SheriffTuer ~locked open;
    give LadenTuer ~locked open;
    move Lucy to r_Gewoelbe;
    move Taschentuch to r_Mine;
    ActivateTopic(Barfrau, 306);
];

! ============================================================
! --- 5: LADEN ---
! ============================================================

[descLaden;
    if (r_Laden hasnt visited) {
        print "Eine kleine Glocke bimmelt hell, als du das Geschäft betrittst. Der Bereich für die Kunden ist so klein, dass sich kaum zwei Personen gleichzeitig umdrehen können.^^Im Durchgang hinter der Ladentheke erscheint der Ladenbesitzer Bill, krächzt ein leises ~Morgen~ und wirft dir ein schiefes Lächeln zu.^^";
    }
    print "Du stehst vor der Ladentheke";
    if (r_Laden has visited) {
        print ", dahinter steht Bill und ";
        print (string) random(
            "stützt sich auf seinen Gehstock",
            "kratzt sich am Kinn",
            "reibt sich die Augen",
            "hustet krächzend");
    }
    print ". Bis auf die offenen Wandregale hinter Bill ist der Laden ziemlich leer.^^Im Süden geht es hinaus auf die Straße.";
    if (Brecheisen in Theke) print "^^Auf der Theke liegt ein Brecheisen.";
    if (Streichhoelzer in Theke) print "^^Auf der Theke liegt ein kleines Papiertütchen mit Streichhölzern.";
];

Room r_Laden "Gemischtwarenladen"
    with name 'laden' 'gemischtwarenladen' 'geschäft',
        description descLaden,
        cheap_scenery
            CS_ADD_LIST r_Laden (sc1),
        sc1
            4 'regal' 'regale' 'wandregal' 'wandregale' descRegale
            2 'schilder' 'schild' 'etiketten' "Du kannst die Schilder nicht lesen, aber du glaubst auch nicht, dass du eines dieser Dinge brauchst."
            1 'fenster' "Ein ziemlich staubiges Fenster zur Straße hinaus."
            2 'durchgang' 'hinterraum' "Ein Durchgang hinter der Theke führt offenbar in ein Lager.",
        s_to LadenTuer, out_to LadenTuer,
        before [;
            Smell: "Es riecht ein bisschen nach altem Mann und nach vielen Aromen, die dich daran erinnern, heute noch nichts gegessen zu haben.";
        ];

[descRegale;
    Examine:
        "Die großen Wandregale sind ziemlich leer. Ein paar Pappschachteln, Dosen, kleine Leinensäcke und große braune Flaschen enthalten offenbar Mehl, Zucker, Bohnen und einige andere Dinge, die du anhand der krakeligen Schilder nicht genauer identifizieren kannst.";
    default: rfalse;
];

Object -> Theke "Ladentheke"
    with name 'ladentheke' 'theke' 'tresen' 'klappe',
        description "Eine breite Theke aus Holz mit einer Klappe als Durchgang.",
    has supporter scenery female;

Object -> Glocke "Glocke"
    with name 'glocke' 'glöckchen' 'ladenglocke',
        description "Ein kleines Glöckchen an der Ladentür, vermutlich aus Messing.",
    has scenery female;

Object -> Warencontainer "Waren"
    with name 'pappschachtel' 'pappschachteln' 'schachtel' 'schachteln' 'sack' 'säcke' 'leinensack' 'leinensäcke' 'flasche' 'flaschen' 'dosen',
        description "In dem Behälter sind Waren die du nicht brauchst. Rede mit Bill wenn du etwas möchtest.",
    has scenery;

Object -> Ware "Waren"
    with name 'mehl' 'zucker' 'bohnen' 'dinge' 'hering' 'heringe' 'werkzeug' 'werkzeuge',
        description "Du möchtest diese Ware nicht kaufen. Rede mit Bill wenn du etwas möchtest.",
        before [;
            Take: "Sprich einfach mit Bill, wenn du etwas kaufen möchtest.";
        ],
    has scenery;

Object Brecheisen "Brecheisen" r_Backstage
    with name 'brecheisen' 'kuhfuss' 'stemmeisen' 'brechstange',
        description "Ein langer Kuhfuss aus Metall. Schwer und robuster als man meinen sollte.",
        before [;
            Drop: noDropValuable(); rtrue;
        ],
    has concealed;

Object Ladenmann "Bill" r_Laden
    with name 'ladenmann' 'bill' 'ladenbesitzer' 'mann',
        description "Der bucklige Ladenbesitzer heißt Bill. Er ist ein alter Mann mit schlohweißem schütterem Haar und einem vernarbten aber freundlich wirkenden Gesicht. Er trägt einen fleckigen Kittel und stützt sich auf einen Gehstock.",
        talk_array talk_array_bill,
        before [;
            Ask, AskFor, AskTo, Tell, Give, Show: "Sag einfach REDE MIT ihm.";
        ],
    has animate proper concealed;

[bi_r340; print "~Naja, muss halt, wa?~^^Bill grinst und präsentiert dabei einen gelben Schneidezahn im Oberkiefer seines ansonsten zahnlosen Mundes.^^~Die Kutsche ist überfällig und ich hab' fast nix mehr. Hoffe es gab keinen Überfall.~"; ];
[bi_r341; print "~Alles, was du hinter mir siehst. Lesen musst du schon selber. Die roten Heringe da verkauf' ich allerdings nicht mehr, die sind schon ein bisschen drüber.~"; ];
[bi_r342; print "Bill lacht laut krächzend auf und erleidet dabei einen kleinen Hustenanfall. Er wischt sich den Mund am Kittel ab und lächelt, den Blick leicht an dir vorbei gerichtet.^^~Tut mir leid Junge. Früher hat meine Frau die Waren beschriftet, aber sie ist leider nicht mehr. Ihre Schrift war wunderschön.~^^Er greift sich gedankenverloren ins Gesicht, schüttelt kurz den Kopf und schaut dich an.^^~Frag' mich einfach, wenn du was Bestimmtes willst, ich weiß dann schon wo's ist. Werkzeug und so hab' ich eh hinten im Lager.~"; ];
[bi_r343; print "Bill kneift misstrauisch die Augen zusammen.^^~Lucy is'n feines Mädchen, was willst du von ihr?~"; ];
[bi_r344; print "Du erzählst Bill, was passiert ist. Er wirkt betroffen.^^~Oh Junge. Weiß leider nicht, wo sie sein könnte, vielleicht bei ihrem Burschen? Hier im Laden war sie jedenfalls schon ein paar Tage nicht mehr, und durch die dreckigen Scheiben seh' ich nicht gut nach draußen. Tut mir leid.~"; ];
[bi_r345; print "Bill blinzelt dich an. ~Einen Meißel? Nee sowas hab' ich nicht.~^^Er überlegt kurz und lächelt. ~Aber 'nen Kuhfuß müsste ich hinten noch irgendwo liegen haben.~"; ];
[bi_r346; print "Der Ladenbesitzer schaut dich verblüfft an und lacht dann krächzend. ~Wo kommst du denn her Junge? Ein Brecheisen halt! Ich hol's mal eben.~^^Er verschwindet im Durchgang hinter der Theke. Ein paar Minuten und einige dubiose Geräusche und Kraftausdrücke später tritt er wieder an die Theke, das spärliche Haupthaar voller Spinnweben.^^~Ich find's leider nicht. Ohne meinen Zwicker seh' ich einfach nicht mehr gut genug.~"; ];
[bi_r347; print "Bill weicht zurück und kneift die Augen zusammen.^^~Und dann brätst du mir da hinten eins über was? Nee nee, du bleibst mal schön hier vorne Junge!~"; ];
[bi_r348; print "Bill blickt gedankenverloren durch die fleckigen Fenster. ~Ich weiß es nicht.~^^Er klopft mit den Fingerknöcheln auf den Tresen. ~War heute früh wie jeden Morgen am Grab meiner Frau, da muss ich ihn noch gehabt haben. Bei dem Sandsturm seh' ich sonst keine fünf Meter weit.~"; sayPageTold(TC_LADENMANN_KNEIFER);
    if (FlagIsSet(F_BILLS_WIFE_FOUND)) { InactivateTopic(Ladenmann, 348); ActivateTopic(Ladenmann, 357); } else { InactivateTopic(Ladenmann, 348); }
];
[bi_r349; print "Du legst den Zwicker behutsam auf den Tresen. Bills Gesicht hellt sich auf und er blickt dich dankbar an.^^~Ja, das ist er! Vielen Dank mein Junge! Ohne den wär' ich auf Dauer ziemlich aufgeschmissen.~"; move Zwicker to Ladenmann; ];
[bi_r357; print "~Sie "; style underline; print "hieß"; style roman; print " Mathilda.~^^Er zieht die Nase hoch und reibt sich im Auge. ~Hab' sie meistens Hildchen genannt.~"; SetFlag(F_BILLS_WIFE_NAMED); ];
[bi_r350; print "~Natürlich! Bin gleich wieder da.~^^Ein endlos scheinendes "; style underline; print "Gleich"; style roman; print " später erscheint Bill wieder im Durchgang und knallt das Brecheisen vor dir auf den Tresen.^^~Macht normalerweise acht Scheine, aber wenn du's nicht ewig brauchst leih' ich's dir aus, scheinst ja 'ne ehrliche Haut zu sein.~"; move Brecheisen to Theke; ];
[bi_r351; print "Bill schaut dich verdutzt an. ~Seh' ich wie ein Baustoffhändler aus? Sowas hab' ich nicht.~"; sayPageTold(TC_LADENMANN_STAB); print "^^Er schließt die Augen, schüttelt dann aber verärgert den Kopf. ~Das Quietschen von diesem verdammten Windrad macht mich noch verrückt, ich sag's dir.~"; InactivateTopic(Ladenmann, 351); ];
[bi_r353; print "Bills Gesicht hellt sich auf. ~Klar hab' ich welche! Die guten alten ohne diesen Sicherheits-Reibescheiß, die kriegste immer an.~^^Er legt ein kleines braunes Papiertütchen auf den Tisch. ~Macht einen Dollar.~^^Du legst einen zerknitterten Dollarschein auf die Theke. Bill steckt ihn ein."; move Streichhoelzer to Theke; Geldbetrag--; ];
[bi_r355; print "Der alte Mann kratzt sich nachdenklich am Kinn und schaut aus dem Fenster.^^~Ich hatte bestimmt zwanzig Meter Tau da. Kamen zwei junge Soldaten und sagten sie brauchen fünf Meter davon.~^^Seine Augen blitzen auf, als sich ein breites Grinsen auf seinem Gesicht ausbreitet.^^~Hab' ihnen gesagt ich kann's nicht durchschneiden, da ham sie das komplette Ding gekauft.~"; ];
[bi_r356; print "~Die ham damals ganz schnell 'n Galgen zusammengezimmert, um ein paar Deserteure zu hängen, draußen vor der Stadt.~^^Bill kneift die Augen zusammen und zieht die Luft ein. Die Erinnerung scheint ihm unangenehm zu sein.^^~Das ganze Dorf sollte zusehen. Kaum war's getan, sind die Soldaten wieder abgezogen, und Marten durfte sich um die Leichen kümmern.~^^Er reibt sich kurz die Nase und blickt dich direkt an. ~Jetzt wo ich so dran denke, den Rest vom Tau hatten sie nicht dabei. Würde mich nicht wundern, wenn das da draußen noch irgendwo rumliegt.~"; ];

Array talk_array_bill -->
    TM_ACTIVE 340 "~Wie geht's?~"
        TM_NO_LINE
        bi_r340
    TM_ACTIVE 341 "~Was gibt's hier?~"
        TM_NO_LINE
        bi_r341
        342
    TM_INACTIVE 342 "~Ich kann die meisten Schilder nicht lesen.~"
        TM_NO_LINE
        bi_r342
    TM_ACTIVE 343 "~Wissen Sie, wo Lucy ist?~"
        TM_NO_LINE
        bi_r343
        344
    TM_INACTIVE 344 "~Lucy ist verschwunden.~"
        TM_NO_LINE
        bi_r344
    TM_INACTIVE 345 "~Haben Sie einen Meißel oder sowas?~"
        TM_NO_LINE
        bi_r345
        346
    TM_INACTIVE 346 "~Was zum Henker ist denn ein Kuhfuß?~"
        TM_NO_LINE
        bi_r346
        347 348
    TM_INACTIVE 347 "~Kann ich vielleicht mal nachsehen?~"
        TM_NO_LINE
        bi_r347
    TM_INACTIVE 348 "~Wo ist denn Ihr Zwicker?~"
        TM_NO_LINE
        bi_r348
    TM_INACTIVE 349 "~Ich glaube, ich habe Ihren Zwicker gefunden.~"
        TM_NO_LINE
        bi_r349
        350
    TM_INACTIVE 350 "~Könnten Sie jetzt nochmal nach dem Brecheisen sehen?~"
        TM_NO_LINE
        bi_r350
    TM_INACTIVE 351 "~Ich könnte eine Stange oder sowas brauchen.~"
        TM_NO_LINE
        bi_r351
    TM_INACTIVE 352 "~Ich könnte eine Schaufel gebrauchen.~"
        TM_NO_LINE
        "'Nee hab' ich leider keine mehr. Meine letzte hab' ich Marten verkauft.'"
    TM_INACTIVE 353 "~Haben Sie vielleicht Streichhölzer für mich?~"
        TM_NO_LINE
        bi_r353
    TM_INACTIVE 354 "~Haben Sie Petroleumlampen?~"
        TM_NO_LINE
        "'Hab' grade keine da Junge, tut mir leid.'"
    TM_INACTIVE 355 "~Ich muss wo runterklettern, haben Sie da was für mich?~"
        TM_NO_LINE
        bi_r355
        356
    TM_INACTIVE 356 "~Wofür haben die das Seil denn gebraucht?~"
        TM_NO_LINE
        bi_r356
        barbierSeilAktivieren
    TM_INACTIVE 357 "~Ähm, wie heißt eigentlich Ihre Frau?~"
        TM_NO_LINE
        bi_r357
    TM_END;

[barbierSeilAktivieren;
    ActivateTopic(Barbier, 375);
];

! ============================================================
! --- 6: BARBIER ---
! ============================================================

[descBarbier;
    if (r_Barbier hasnt visited) {
        print "Du stupst kurz die rot-weiß-blaue Säule neben der Eingangstür an und betrittst das Geschäft. Du bist angenehm überrascht, wie hell und sauber es hier ist.^^";
    }
    print "Ein ausladender Kippsessel aus rotem Leder prangt vor einem großen, an der Wand befestigten Spiegel. Auf diversen Tischen und Regalen stehen kleine Fläschchen, Dosen und allerlei Krimskrams herum.";
    if (Papagei in r_Barbier) {
        print "^^";
        if (Papagei has proper) print "Molly";
        else print "Ein Papagei";
        print " sitzt auf einer Stange und wackelt mit dem Kopf. ";
    }
    if (Barbier has proper) print "Marten";
    else print "Der Barbier";
    print " steht hinter dem Sessel und ";
    print (string) random(
        "popelt in der Nase",
        "poliert den Spiegel",
        "sortiert einige Döschen",
        "prüft sein Rasiermesser",
        "prüft sein Rasiermesser");
    ".";
];

Room r_Barbier "Barbier"
    with name 'barbier' 'friseur' 'barbiergeschäft' 'geschäft',
        description descBarbier,
        cheap_scenery
            CS_ADD_LIST r_Barbier (sc1),
        sc1
            5 'sessel' 'kippsessel' 'leder' 'stuhl' 'sitz' "Ein großer Sessel aus rotem Leder, der sich in der Höhe verstellen lässt. Du hast keine Zeit für Dienstleistungen."
            2 'spiegel' 'wandspiegel' 'wand' "Du könntest eine Rasur vertragen. Und einen Haarschnitt. Und ein Bad."
            7 'krimskrams' 'kram' 'tisch' 'tische' 'regal' 'regale' 'flaeschchen' "Dieser ganze Frisörkram interessiert dich nicht weiter."
            1 'stange' "Die Stange, auf der der Papagei sitzt.",
        sw_to r_Hauptstrasse, out_to r_Hauptstrasse,
        before [;
            Smell: "Es riecht ziemlich gut hier. Irgendwie frisch.";
        ];

Object Schaufel "Schaufel" r_Backstage
    with name 'schaufel' 'grabschaufel' 'metallschaufel',
        description "Eine große Metallschaufel. Ein bisschen schäbig aber funktionsfähig.",
        before [;
            Drop: noDropValuable(); rtrue;
        ],
    has female;

Object Barbier "Barbier" r_Barbier
    with name 'barbier' 'marten' 'friseur' 'nase',
        short_name "Barbier",
        description "Der Barbier ist ein stämmiger Mann mit dicken Oberarmen und einem gepflegten schwarzen Vollbart. Er trägt eine gestreifte Stoffweste und eine kurze Leinenhose.",
        talk_array talk_array_barbier,
        before [;
            Talk:
                if (FlagIsClear(F_MARTEN_KNOWN)) {
                    print "Der Barbier geht einen kleinen Schritt auf dich zu und grinst dich freundlich an.^^~Moin Mister. Mein Name ist Marten, was kann ich für Sie tun? Bart stutzen, Haare schneiden, Schusswunde versorgen?~^^";
                    barbierEnthuelleNamen();
                    rfalse;
                }
            Ask, AskFor, AskTo, Tell, Give, Show: "Sag einfach REDE MIT ihm.";
        ],
    has animate concealed;

Object Papagei "Papagei" r_Barbier
    with name 'papagei' 'molly' 'vogel' 'blackbeard',
        short_name "Papagei",
        description descPapagei,
        before [;
            Take: nehmePapagei(); rtrue;
            Push, Pull: nehmePapagei(); rtrue;
            Listen: "'Braak!'";
        ],
    has animate concealed;

[descPapagei;
    if (Papagei in player) { "'Braaak!'"; }
    if (Papagei in r_Barbier) {
        if (Papagei has proper) print "Molly";
        else print "Ein schöner Papagei";
        print " trippelt friedlich auf ";
        if (Papagei has proper) print "ihrer";
        else print "seiner";
        print " Stange auf und ab.";
        if (FlagIsSet(F_MOLLY_TRUSTING)) print "^Der Papagei blickt sich erwartungsvoll an.";
        new_line;
    }
];

[nehmePapagei;
    if (Papagei in player) "Du hast den Papagei doch schon.";
    if (FlagIsClear(F_MOLLY_TRUSTING) && FlagIsClear(F_MOLLY_TAKEABLE)) {
        print (The) Barbier; print " wirft dir einen misstrauischen Blick zu. Du lässt es erstmal bleiben.^"; rtrue;
    }
    if (FlagIsSet(F_MOLLY_TRUSTING) && FlagIsSet(F_MOLLY_TAKEABLE)) {
        print "Du hältst Molly deinen ausgestreckten Arm entgegen. ";
        if (Papagei has proper) print "Sie";
        else print "Er";
        print " schaut kurz zu Marten der wohlwollend nickt, dann hoppelt ";
        if (Papagei has proper) print "sie";
        else print "er";
        print " auf deinem Arm entlang und macht es sich auf deiner linken Schulter bequem.^^~BRAAAK!~^";
        move Papagei to player;
        give Papagei proper;
        Papagei.short_name = "Molly";
        rtrue;
    }
    if (FlagIsSet(F_MOLLY_TRUSTING)) {
        print "Du hältst Molly deinen ausgestreckten Arm entgegen. ";
        if (Papagei has proper) print "Sie";
        else print "Er";
        print " trippelt dir entgegen, schaut kurz zu Marten und hüpft dann wieder auf ";
        if (Papagei has proper) print "ihre";
        else print "seine";
        print " Stange.^";
        rtrue;
    }
    print "Du hältst Molly deinen ausgestreckten Arm entgegen. ";
    if (Papagei has proper) print "Sie";
    else print "Er";
    print " legt den Kopf schief und blickt dich erwartungsvoll an, rührt sich aber nicht vom Fleck.^";
    rtrue;
];

[mart_r360; print (The) Barbier; print " lacht herzlich und hält sich den Bauch.^^~Entschuldigen Sie Mister, ich kann mir das nicht ganz abgewöhnen. Ich bin nämlich Friese.~"; ];
[mart_r361; print "~Bin vor über zehn Jahren mit'm Kahn hergekommen, war erster Maat. Wollte eigentlich mit Molly auf Goldsuche gehen, aber dann kam der Krieg dazwischen.~"; ];
[mart_r362; print "Marten lacht dröhnend.^^~Als Barbier auf hoher See ist es immer ganz nützlich, wenn man sich auch ein bisschen mit der Versorgung von Wunden auskennt. Außerdem gibt es hier keinen Arzt mehr.~^^Er zieht eine kleine Pfeife aus der Tasche und drückt mit einer geübten Bewegung etwas Tabak hinein.^^~Und bevor du fragst, ich bin außerdem der Totengräber hier. Ist seit dem Krieg zum Glück nicht mehr so oft gefragt.~"; ];
[mart_r363; print "~Meine Frau? Haa-ha-ha!~^^"; print (The) Barbier; print " kann kaum an sich halten und klopft sich auf die Schenkel.^^~Molly is' mein Vogel meen Jong! Ham' schon viel gemeinsam erlebt auf See. War als Feuermelder mit dabei, beim kleinsten bisschen Rauch schlägt sie Alarm.~";
    told_count->TC_BARBIER_MOLLY = 1; ! pg-Barbier-molly2 starts with Toldcounter=1 in I7
];
[mart_r364;
    print "~War als Feuermelder mit dabei, beim kleinsten bisschen Rauch schlägt sie Alarm.";
    sayPageTold(TC_BARBIER_MOLLY);
    print "~";
];
[mart_r370; print "~Die Mine? Was willst'n da?~^^Du erzählst Marten, was los ist. Zum ersten Mal macht er ein ernstes Gesicht.^^~Aah. Üble Geschichte. Glaub' nicht, dass du vorne reinkommst, mit den Jungs da ist nicht gut Kirschen essen. Vielleicht gibt's noch einen anderen Eingang.~"; ];
[mart_r371; print "~Wat, mein' Vogel willste mitnehmen? Wegen Lucy ne?~^^Marten kratzt sich nachdenklich an dem tätowierten Anker auf seinem rechten Oberarm.^^~Also wennse freiwillig mit dir mitgeht, soll's mir recht sein. Die haut dann schon ab, wenn's brenzlig wird. Aber trotzdem, pass ja gut auf sie auf!~"; ];
[mart_r372;
    print "Marten lacht dröhnend und blinzelt dich an.^^~Jo meinste ich heb' die Gräber hier mit den Händen aus oder wat? Klar hab' ich eine Schaufel! Erst vor ein paar Tagen 'ne neue bei Bill geholt, dem ollen Geizkragen!~";
    if (FlagIsSet(F_PLATFORM_KNOWN)) {
        InactivateTopic(Barbier, 373);
        ActivateTopic(Barbier, 374);
    } else {
        ActivateTopic(Barbier, 373);
    }
];
[mart_r373; print "Marten lacht und knufft dich in die linke Schulter. ~Meine Schaufel? Na da kann ja jeder kommen. Nee einfach so kriegste die nicht."; sayPageTold(TC_BARBIER_SCHAUFEL); print "~^^"; ReActivateTopic(Barbier, 373); ];
[mart_r374; print "~Ist das für die Lucy-Sache?~ fragt Marten. Du bejahst. Er legt den Kopf schief und krault sich den Bart. ~Gut, hol' ich dir.~^^Er verschwindet kurz im hinteren Teil des Ladens und taucht kurz darauf mit einer großen Metallschaufel in der Hand wieder auf.^^~Is'n bissken schettrig aber kannste ja sauber machen wenn's dich stört. Wiedersehen macht Freude!~^^Du nimmst die Schaufel und bedankst dich."; move Schaufel to player; InactivateTopic(Barbier, 373); InactivateTopic(Barbier, 374); ];
[mart_r375; print "Marten zuckt zusammen und blickt dich argwöhnisch an.^^~Nee war ich nich. Ich war leider dabei, als er eingeweiht wurde, und durfte danach zwei Tage ranklotzen, bis alle verscharrt waren. Wieso fragst du?~"; ];
[mart_r376; print "~Ja klar meen Jong. Ich durfte ja alles wegräumen.~^^Er schüttelt den Kopf und räuspert sich.^^~Die Soldaten haben mir ein bisschen Geld gegeben und gesagt, allen übrigen Kram rein in die Luke und feste zunageln, die Schlinge durchschneiden und die Leichen begraben. War ein lächerlicher Lohn für die ganze Arbeit, aber Nein zu sagen wär' sicher keine gute Idee gewesen.~"; ];
[mart_r377; print "~Ja klar meen Jong. Ich durfte ja alles wegräumen. Rein in die Luke und feste zunageln.~"; ];

Array talk_array_barbier -->
    TM_ACTIVE 360 "~Moin? Es ist schon Mittag.~"
        TM_NO_LINE
        mart_r360
        361
        barbierEnthuelleNamen
    TM_INACTIVE 361 "~Was hat Sie denn hierher verschlagen?~"
        TM_NO_LINE
        mart_r361
        363
    TM_ACTIVE 362 "~Schusswunde? Ich dachte Sie sind Barbier.~"
        TM_NO_LINE
        mart_r362
    TM_INACTIVE 363 "~Ist Molly Ihre Frau?~"
        TM_NO_LINE
        mart_r363
        barbierEnthuelleNamenMolly
    TM_INACTIVE 364 "~Wieso war Molly noch gleich mit auf See?~"
        TM_NO_LINE
        mart_r364
        364
    TM_INACTIVE 370 "~Eine Idee wie ich in die Mine komme?~"
        TM_NO_LINE
        mart_r370
        371
        barbierInformiertUeberLucy
    TM_INACTIVE 371 "~Kann ich mir Molly mal ausleihen?~"
        TM_NO_LINE
        mart_r371
        F_MOLLY_TAKEABLE
    TM_INACTIVE 372 "~Sie haben doch bestimmt eine Schaufel, oder?~"
        TM_NO_LINE
        mart_r372
    TM_INACTIVE 373 "~Können Sie mir die Schaufel leihen?~"
        TM_NO_LINE
        mart_r373
    TM_INACTIVE 374 "~Können Sie mir die Schaufel leihen? Es ist wirklich wichtig.~"
        TM_NO_LINE
        mart_r374
    TM_INACTIVE 375 "~Waren Sie damals dabei als der Galgen gebaut wurde?~"
        TM_NO_LINE
        mart_r375
        376
    TM_INACTIVE 376 "~Bill meinte da müsste 'ne Menge Seil übriggeblieben sein, wissen Sie wo das abgeblieben ist?~"
        TM_NO_LINE
        mart_r376
    TM_INACTIVE 377 "~Bill meinte da müsste ein Menge Seil übriggeblieben sein.~"
        TM_NO_LINE
        mart_r377
    TM_END;

[barbierEnthuelleNamen;
    if (FlagIsClear(F_MARTEN_KNOWN)) {
        SetFlag(F_MARTEN_KNOWN);
        Barbier.short_name = "Marten";
        give Barbier proper;
    }
];

[barbierEnthuelleNamenMolly;
    if (Papagei hasnt proper) {
        give Papagei proper;
        Papagei.short_name = "Molly";
        give Papagei female;
        ActivateTopic(Barbier, 364);
    }
];

[barbierInformiertUeberLucy;
    if (FlagIsSet(F_PLATFORM_KNOWN)) {
        if (GetTopicStatus(Barbier, 372) == TM_ACTIVE) {
            InactivateTopic(Barbier, 374);
        } else {
            ActivateTopic(Barbier, 374);
        }
        InactivateTopic(Barbier, 373);
    }
];

! ============================================================
! --- 7: RANCH ---
! ============================================================

[descRanch;
    r_Ranch.visitcounter++;
    if (r_Ranch hasnt visited) {
        print "Du kommst zu einem kleinen Holzhaus mit angrenzendem Stall und einer großen umzäunten Koppel.^^";
    } else {
        print "Ein kleines Holzhaus mit angrenzendem Stall und einer umzäunten Koppel. Vor dem Haus steht eine kleine Bank.^^";
    }
    if (Lucy in r_Ranch) {
        print "Eine junge Frau sitzt schluchzend auf einer kleinen Bank.^";
    } else {
        print "Ein schmaler Weg führt nach Süden zum Windrad. Die Hauptstraße führt von Osten kommend weiter nach Westen aus der Stadt hinaus.^";
    }
    if (r_Ranch.visitcounter == 2 && Lucy in r_Gewoelbe) {
        "^Ein dumpfer Knall aus westlicher Richtung gefolgt von leisem Fluchen lässt dich kurz aufhorchen.";
    } else if (r_Ranch.visitcounter == 4) {
        "^Etwas zischt an deinem Kopf vorbei und landet vor dir in der Pferdekoppel. Ein kleiner Junge sprintet heran und springt über den Zaun.^^Kurz darauf kommt er mit einem Stoffball unter dem Arm wieder zum Vorschein und rennt davon. ~Sie ham nix gesehen Mister!~";
    } else if (r_Ranch.visitcounter == 7) {
        "^Du hörst das leise Rasseln einer Klapperschlange. Als du mit gezogenem Revolver neben das Haus trittst, verschwindet sie schnell in Richtung Steppe.";
    } else if (r_Ranch.visitcounter == 10) {
        "^Ein dürrer Hund jagt keuchend in einem Affentempo an dir vorbei, ein Stück Dörrfleisch zwischen den Zähnen. Einige Häuser weiter hörst du jemanden leise fluchen.";
    }
];

Room r_Ranch "Ranch"
    with name 'ranch' 'hof',
        description descRanch,
        cheap_scenery
            CS_ADD_LIST r_Ranch (sc1),
        sc1
            2 'holzhaus' 'haus' 'häuschen' 'schuppen' "Ein kleines Holzhäuschen mit einem flachen, leicht schrägen Dach, kaum mehr als ein Schuppen."
            2 'koppel' 'zaun' "Eine kleine Pferdekoppel, durch einen hüfthohen Zaun eingefasst. Es gibt hier nichts außer vertrocknetem Steppengras."
            2 'stall' 'pferdestall' "Einige Pferde bewegen sich unruhig im Stall umher."
            1 'bank' 'sitzbank' "Eine einfache Sitzbank, aus Holz gezimmert."
            3 'pferde' 'pferd' 'gaul' "Die Pferde scheinen unruhig zu sein.",
        e_to r_Hauptstrasse,
        s_to r_Windrad,
        w_to r_Mine,
        before [;
            Smell: "Es riecht hauptsächlich nach Stroh und Pferdescheiße.";
            Go:
                if (Lucy in r_Ranch) {
                    if (selected_direction == e_to or s_to or w_to or
                        n_to or ne_to or nw_to or se_to or sw_to)
                        "Du kannst die junge Frau nicht einfach so hier sitzen lassen.";
                }
                if (selected_direction == e_to && Stange in player) {
                    print "Mit der langen Metallstange solltest du dich in der Stadt nicht blicken lassen.^";
                    move Stange to r_Ranch;
                    ! rfalse: proceed with move
                }
                if (selected_direction == n_to or ne_to or nw_to or se_to or sw_to)
                    return PrintDescOOB();
        ];

Object Lucy "Frau" r_Ranch
    with name 'lucy' 'frau' 'mädchen',
        adj "jung",
        description [;
            if (Lucy in r_Ranch)
                "Die junge Frau hat ihr Gesicht in den Händen vergraben und bemerkt dich nicht. Sie trägt zweckmäßige, robuste Kleidung und wirkt sehr gepflegt.";
            else
                "Die junge Frau trägt zweckmäßige, robuste Kleidung und wirkt sehr gepflegt.";
        ],
        talk_array talk_array_lucy,
        before [;
            Ask, AskFor, AskTo, Tell, Give, Show: "Sag einfach REDE MIT ihr.";
        ],
    has animate female concealed;

[lucy_r390;
    if (Lucy hasnt proper) print "Die junge Frau";
    else print "Lucy";
    print " blickt zu dir hoch, die Augen tränenüberströmt. ~Michael ist weg!~";
];
[lucy_r391; 
    if (Lucy hasnt proper) print "Die junge Frau";
    else print "Lucy";
    print " schnäuzt einmal in ihr Taschentuch. ~Michael ist mein Verlobter. Er wollte gestern noch in den Saloon.~^^Sie holt tief Luft und deutet hinüber zu den Pferden.^^~Als ich heute Morgen hergekommen bin, waren die Pferde nicht versorgt und von Michael keine Spur. Er würde die Pferde niemals sich selbst überlassen!~"; 
];
[lucy_r392; print "~Ich bin Lucy.~"; give Lucy proper; Lucy.short_name = "Lucy"; InactivateTopic(Lucy, 392); ];
[lucy_r393;
    ranchKnockout();
];

Array talk_array_lucy -->
    TM_ACTIVE 390 "~Kann ich Ihnen vielleicht helfen Ma'am?~"
        TM_NO_LINE
        lucy_r390
        391 392
    TM_INACTIVE 391 "~Wer ist Michael?~"
        TM_NO_LINE
        lucy_r391
        393
    TM_INACTIVE 392 "~Wie heißen Sie?~"
        TM_NO_LINE
        lucy_r392
    TM_INACTIVE 393 "~Haben Sie eine Idee, was passiert sein könnte?~"
        TM_NO_LINE
        lucy_r393
    TM_INACTIVE 400 "~Alles klar bei euch?~"
        TM_NO_LINE
        lucy_r400
    TM_INACTIVE 401 "~Was ist hier passiert?~"
        TM_NO_LINE
        lucy_r401
    TM_END;

[lucy_r400;
    if (FlagIsClear(F_GUARD_OUT)) {
        "~Pssst! Wart' bis die Wache weg ist!~^^Lucy flüstert kaum hörbar.";
    }
    if (FlagIsSet(F_LUCY_FREE)) { rfalse; }
    print "Lucy funkelt dich an, ihr Gesichtsausdruck eine wilde Mischung aus Verzweiflung und blanker Wut. ~Hol' uns bitte hier raus, verdammt!~^^";
    print "Du hebelst die Gitter mit Hilfe deines Brecheisens auseinander, so dass sich beide gerade so hindurchzwängen können.^^";
    print "Der junge Mann atmet erleichtert auf und streckt dir die Hand entgegen. ~Vielen Dank Sir. Ich bin Michael.~^";
    SetFlag(F_LUCY_FREE);
    give Michael ~concealed;
    ActivateTopic(Lucy, 401);
];

[lucy_r401;
    print "~Dafür haben wir jetzt keine Zeit!~, zischt Lucy aufgeregt. ~Die panschen hier irgendeine Sauerei zusammen, und mein Stiefvater steckt da mit drin!~^^Ihre Augen weiten sich und sie zieht euch beide hastig zurück hinter den schmalen Felsvorsprung. ~Achtung, da kommen sie!~^";
    SetFlag(F_LUCY_LISTENING);
    talk_menu_talking = false;
    descVaultThompson();
    SetFlag(F_VAULT_SHOWDOWN);
    give VaultKarren ~concealed;
    give VaultKeil ~concealed;
    give Maenner ~concealed;
    give VaultThompson ~concealed;
];

[ranchKnockout;
    if (Lucy hasnt proper) print "Sie";
    else print "Lucy";
    print " wendet den Blick ab.^^~Ich weiß es nicht. Bevor er gestern gegangen ist, hat er kurz gesagt, dass er etwas über die Mifflin-Brüder gehört hat. Als ich wissen wollte, was genau hat er mich nachdenklich angesehen und gemeint, es sei doch nicht so wichtig.~^^";
    if (Lucy hasnt proper) print "Die junge Frau";
    else print "Lucy";
    print " wendet sich dir wieder zu. Ihr Blick streift dein Gesicht, ihre Augen weiten sich angsterfüllt.^^~He, was--~^^";
    style bold; print "BAUZ!"; style roman;
    print "^^";
    doScreenbreak();
    style underline; print "Claire wirbelt herum. ~Zur Armee? Bist du völlig bescheuert?~^^Sie ist so schön, wenn sie wütend ist, aber das funkelnde Feuer in ihren Augen macht dir manchmal auch ein bisschen Angst. Als du ihr über die Wange streichen möchtest, dreht sie sich schnell weg.^^~Du weißt doch, dass wir das Geld brauchen.~^^Du versuchst möglichst fest und bestimmt zu klingen, dabei bist du selbst nicht ganz überzeugt von deiner Entscheidung. Trotzig blickt sie aus dem staubigen Fenster, die Arme vor der Brust verschränkt. Ihr Kinn zittert leicht.^^Claire...^"; style roman;
    print "^";
    doScreenbreak();
    SetFlag(F_PLAYER_LOCKED_UP);
    move Revolver to Tasche;
    if (Tasche in player) {
        Tasche.&name->0 = 'tasche'; ! reset open state
        give Tasche ~open;
        move Tasche to Schreibtisch;
    }
    move Einberufungsbescheid to Schreibtisch;
    PlayerTo(r_Sheriff, true);
    give r_Sheriff visited;
    ActivateTopic(Sheriff, 320);
    print "Aua.^^Dein Kopf dröhnt schon wieder, nur dass es sich diesmal nicht wie zu viel Whiskey am Vorabend anfühlt.^^~Kleines Schläfchen gehalten, was?~^^Du öffnest langsam die Augen und blickst unvermittelt in das wettergegerbte Gesicht des Sheriffs.^";
    talk_menu_talking = false;
];

! ============================================================
! --- 8: GALGEN ---
! ============================================================

[descGalgen;
    r_Galgen.visitcounter++;
    if (r_Galgen hasnt visited) {
        print "Als du das letzte Gebäude passierst, trifft dich der Wind hart von der Seite. Du ziehst dir dein Halstuch über die Nase und gehst langsam weiter. Nach ein paar Metern kannst du in der Staubwolke vor dir allmählich eine Art Gerüst erkennen.^^";
    }
    print "Du stehst vor einem Galgen, bestehend aus zwei Pfosten mit Querbalken und einer Schlinge. Ein Holzpodest dient als Fundament.^^";
    print "Weiter nördlich glaubst du einige schiefe Kreuze zu erkennen. Nach Westen geht es zurück in die Stadt.^";
    if (r_Galgen.visitcounter == 3) {
        print "^~Suchen wohl Ihre Freunde, was? Sowas wie Sie wollen wir hier nicht mehr sehen!~^^Du blickst dich verdutzt um und siehst eine ältere Frau in einem der Häuser verschwinden, mit ihrem Gehstock wild in der Luft herumstochernd.^";
    }
];

Room r_Galgen "Galgen"
    with name 'galgen' 'gerüst',
        description descGalgen,
        w_to r_Hauptstrasse,
        n_to r_Friedhof,
        before [;
            Smell: "Der Wind hier ist zu schneidend, um irgendetwas zu riechen.";
            Go:
                if (selected_direction == nw_to or ne_to or e_to or
                    s_to or sw_to or se_to or in_to)
                    return PrintDescOOB();
        ];

Object GalgenScenery "Galgen" r_Galgen
    with name 'galgen' 'gerüst' 'pfosten' 'balken' 'querbalken',
        description "Der Galgen besteht aus zwei senkrechten Pfosten und einem dicken Querbalken.",
    has scenery;

Object Schlinge "Schlinge" r_Galgen
    with name 'schlinge' 'ende',
        description "Die Schlinge hängt reglos am Querbalken.",
        before [;
            Take:
                if (FlagIsSet(F_PLATFORM_OPEN) && Seil in r_Galgen) {
                    <<Take Seil>>;
                    rtrue;
                }
                "Selbst wenn du die Schlinge entknoten könntest, wäre dir das Seil in dieser Form nicht von Nutzen.";
        ],
    has scenery female;

[descPodest;
    if (Podest hasnt general) {
        ! not entdeckt
        print "Ein offenbar eilig zusammengezimmertes Holzpodest bildet das Fundament des Galgens. Es ist beinahe vollständig mit Sand bedeckt.^";
    } else if (FlagIsClear(F_PLATFORM_OPEN)) {
        ! entdeckt but not geöffnet
        print "Auf dem Podest wurde direkt unter dem Galgen eine große Holzplatte festgenagelt.^";
    } else {
        ! Platte aufgehebelt - show lamp view
        if (Lampe in player && Lampe has on) {
            print "Du leuchtest mit deiner Lampe in die Öffnung hinein. Einige Mäuse nehmen quiekend Reißaus.^^";
            if (Seil in r_Galgen)
                "Im fahlen Schein der Lampe kannst du einige krummgeschlagene Nägel, ein paar in Spinnweben eingehüllte Bretter und ein aufgerolltes Tau erkennen.";
            "Im fahlen Schein der Lampe kannst du einige krummgeschlagene Nägel und ein paar in Spinnweben eingehüllte Bretter erkennen.";
        } else {
            ActivateTopic(Barfrau, 309);
            ActivateTopic(Ladenmann, 353);
            "Es ist zu dunkel, um dort hineinzusehen, und du möchtest da nicht einfach die Hand hineinstecken.";
        }
    }
];

Object Podest "Holzpodest" r_Galgen
    with name 'podest' 'holzpodest' 'fundament' 'balken' 'platte' 'holzplatte' 'öffnung' 'loch' 'brett',
        description descPodest,
        before [;
            Take, Push, Pull, Open, Rub:
                if (Podest hasnt general) { <<Examine GalgenSand>>; rtrue; }
                if (FlagIsSet(F_PLATFORM_OPEN)) { "Das Podest ist bereits geöffnet."; }
                "Ohne geeignetes Werkzeug ist das ein sinnloses Unterfangen.";
            Enter: <<Examine self>>;
            Search: "Das Podest ist vollständig mit dicken Balken verschlossen.";
            Receive:
                if (noun == Schaufel && FlagIsClear(F_PLATFORM_DUG)) {
                    <<UseTogether Schaufel GalgenSand>>;
                    rtrue;
                }
                if (noun == Brecheisen && FlagIsSet(F_PLATFORM_DUG) && FlagIsClear(F_PLATFORM_OPEN)) {
                    SetFlag(F_PLATFORM_OPEN);
                    give Podest open;
                    give Seil ~concealed;
                    "Etwa eine halbe Stunde und einen abgebrochenen Fingernagel später hast du alle Nägel erfolgreich entfernt. Schweißgebadet schiebst du die Holzplatte beiseite und legst eine quadratische, dunkle Öffnung frei.";
                }
                rfalse;
        ],
    has scenery neuter;

[descGalgenSand;
    print "Der Sand bildet eine kleine Düne und geht dir an der höchsten Stelle bis zum Knie. Vom Boden des Podests ist praktisch nichts mehr zu sehen.^";
    if (Schaufel notin player) {
        ActivateTopic(Ladenmann, 352);
        ActivateTopic(Barbier, 372);
        SetFlag(F_PLATFORM_KNOWN);
        barbierInformiertUeberLucy();
    }
];

Object GalgenSand "Sand" r_Galgen
    with name 'sand' 'düne',
        description descGalgenSand,
        before [;
            Take, Push, Pull, Rub:
                if (FlagIsSet(F_PLATFORM_DUG)) { "Du hast genug mit dem Sand gekämpft."; }
                print "Du versuchst den Sand mit den Füßen beiseite zu scharren, aber bei diesem Wind scheint das ein sinnloses Unterfangen zu sein. Vielleicht hättest du mit ordentlichem Werkzeug mehr Erfolg.^";
                ActivateTopic(Ladenmann, 352);
                ActivateTopic(Barbier, 372);
                SetFlag(F_PLATFORM_KNOWN);
                barbierInformiertUeberLucy();
                rtrue;
            Receive:
                if (noun == Schaufel) {
                    if (Schaufel notin player) { print "Du hast die Schaufel nicht dabei.^"; rtrue; }
                    if (FlagIsSet(F_PLATFORM_DUG)) { "Du bist mit dem Ergebnis eigentlich zufrieden."; }
                    SetFlag(F_PLATFORM_DUG);
                    give Podest general;
                    give Eisenplatte ~concealed;
                    "Stück um Stück befreist du das Podest von dem großen Sandhaufen, während dir der Wind unerbittlich ins Gesicht peitscht.^^Direkt unter dem Galgen wird eine stabile Holzplatte sichtbar, die gewissenhaft mit vielen großen Nägeln auf dem Podest festgenagelt wurde.";
                }
                rfalse;
        ],
    has scenery;

Object Eisenplatte "eiserne Falltür" r_Galgen
    with name 'eisenplatte' 'falltür' 'eisen' 'platte' 'metallplatte',
        description "Eine rechteckige eiserne Falltür, etwa zwei Handbreit auf zwei Handbreit, bündig in das Holzpodest eingelassen.",
        before [;
            Open, Pull, Take:
                "Sie ist fest verkeilt. Du brauchst einen Hebel, um sie aufzubrechen.";
            Receive:
                if (noun == Brecheisen) {
                    SetFlag(F_PLATFORM_OPEN);
                    give Podest open;
                    give Seil ~concealed;
                    "Etwa eine halbe Stunde und einen abgebrochenen Fingernagel später hast du alle Nägel erfolgreich entfernt. Schweißgebadet schiebst du die Platte beiseite und legst eine quadratische, dunkle Öffnung frei.";
                }
                rfalse;
        ],
    has concealed scenery neuter;

Object Seil "Seil" r_Galgen
    with name 'seil' 'tau' 'strick' 'rolle',
        description "Ein langes, dickes Seil, mindestens zehn Meter lang.",
        before [;
            Take:
                if (FlagIsSet(F_ROPE_TIED)) "Du lässt es lieber dort.";
                if (player in r_Galgen && (Lampe notin player || Lampe hasnt on)) {
                    ActivateTopic(Barfrau, 309);
                    ActivateTopic(Ladenmann, 353);
                    "Es ist zu dunkel, um dort hineinzusehen, und du möchtest da nicht einfach die Hand hineinstecken.";
                }
                give self ~scenery;
                move self to player;
                "Du wirfst dir das aufgerollte Seil über die Schulter. Ganz schön schwer.";
        ],
    has concealed scenery;

Object GalgenKreuze "Kreuze" r_Galgen
    with name 'kreuz' 'kreuze' 'holzkreuze',
        description "Einige verwitterte Holzkreuze stehen etwas nördlich im Staub.",
    has scenery pluralname;

Object GalgenStadt "Stadt" r_Galgen
    with name 'dorf' 'häuser' 'haus' 'stadt',
        description "Von hier aus wirkt die Stadt noch stiller als sonst.",
    has scenery female;

! ============================================================
! --- 9: FRIEDHOF ---
! ============================================================

[descFriedhof;
    r_Friedhof.visitcounter++;
    if (r_Friedhof hasnt visited) {
        print "Du gehst einige Schritte weiter auf die Kreuze zu. Halbhohes Buschwerk schützt die Grabstätten und deren Besucher vor dem Wind.^^";
    }
    print "Mehrere schiefe Kreuze stehen achtlos nebeneinander auf einen kleinen Hügel gepfercht, keines davon beschriftet. Möglicherweise die letzte Ruhestätte von Deserteuren.^^";
    print "Weiter vorne stehen vier Kreuze sauber aufgereiht nebeneinander, jeweils am Kopfende eines ordentlich mit Steinen eingefassten Grabes.^^";
    print "Im Süden siehst du die Umrisse des Galgens.^";
    if (r_Friedhof.visitcounter == 2) {
        print "^^Ein Gecko sitzt starr auf einem der Grabkreuze und sonnt sich. Als du die Hand nach ihm ausstreckst, verschwindet er blitzartig im Gebüsch.^";
    }
];

Room r_Friedhof "Friedhof"
    with name 'friedhof' 'gräber' 'grabfeld',
        description descFriedhof,
        s_to r_Galgen,
        before [;
            Smell: "Der Wind verweht jeden Geruch.";
            Go:
                if (selected_direction == nw_to or n_to or ne_to or
                    e_to or sw_to or se_to or w_to)
                    return PrintDescOOB();
        ];

Object FriedhofBuschwerk "Buschwerk" r_Friedhof
    with name 'buschwerk' 'busch' 'büsche' 'gebüsch',
        description "Kleine Büsche fassen den Friedhof ein und bieten etwas Schutz vor dem schneidenden Wind.",
    has scenery neuter;

Object FriedhofKreuze "Grabkreuze" r_Friedhof
    with name 'kreuz' 'kreuze' 'grabkreuz' 'grabkreuze' 'hügel',
        description [; KreuzMenu(); rtrue; ],
    has scenery pluralname;

Object FriedhofGraeber "Gräber" r_Friedhof
    with name 'grab' 'gräber' 'grabstätte' 'grabstätten' 'steine',
        description [; GraebMenu(); rtrue; ],
    has scenery pluralname;

Object Zwicker "Zwicker" r_Laden
    with name 'zwicker' 'brille' 'kneifer',
        description "Ein altmodischer Zwicker, einer der Gläser ist ein wenig verschmutzt.",
    has concealed;

[KreuzMenu val;
    print "Welches der Kreuze möchtest du lesen?^^";
    while (true) {
        print "[1] Erstes Kreuz^";
        print "[2] Zweites Kreuz^";
        print "[3] Drittes Kreuz^";
        print "[4] Viertes Kreuz^";
        print "[0] Beenden^^";
        PrintMsg(MSG_PROMPT);
        buffer->1 = 0;
        @aread buffer parse -> num_words;
        num_words = parse->1;
        if (num_words == 0) val = -1;
        else val = TryNumber(1);
        if (val == 0) { new_line; Look(); rtrue; }
        switch (val) {
            1: print "[Erstes Kreuz]^^'Biff Clayton'^'1837-1868'^";
            2: print "[Zweites Kreuz]^^'Mathilda Brooks geb. Walker'^'1808-1869'^";
               SetFlag(F_BILLS_WIFE_FOUND);
               if (GetTopicStatus(Ladenmann, 348) == TM_STALE)
                   ActivateTopic(Ladenmann, 357);
               if (FlagIsSet(F_BILLS_WIFE_NAMED))
                   print "Das ist wahrscheinlich das Grab von Bills Frau.^";
            3: print "[Drittes Kreuz]^^'Wendy Porter'^'1816-1875'^";
            4: print "[Viertes Kreuz]^^'Lucille Thompson geb. Powell'^'1845-1878'^";
            default: continue;
        }
    }
];

[GraebMenu val;
    print "Welches der Gräber möchtest du untersuchen?^^";
    while (true) {
        print "[1] Erstes Grab^";
        print "[2] Zweites Grab^";
        print "[3] Drittes Grab^";
        print "[4] Viertes Grab^";
        print "[0] Beenden^^";
        PrintMsg(MSG_PROMPT);
        buffer->1 = 0;
        @aread buffer parse -> num_words;
        num_words = parse->1;
        if (num_words == 0) val = -1;
        else val = TryNumber(1);
        if (val == 0) {
            new_line;
            if (FlagIsSet(F_PINCENEZ_FOUND) && Zwicker notin player && Zwicker notin Ladenmann) {
                move Zwicker to player;
                InactivateTopic(Ladenmann, 348);
                ActivateTopic(Ladenmann, 349);
            }
            Look(); rtrue;
        }
        switch (val) {
            1, 3, 4: print "Du siehst nichts Besonderes, und ohne triftigen Grund möchtest du nicht auf dem Grab herumwühlen.^";
            2: descGrab2();
            default: continue;
        }
    }
];

[descGrab2;
    if (FlagIsSet(F_BILLS_WIFE_NAMED) && FlagIsSet(F_BILLS_WIFE_FOUND) &&
        Zwicker notin player && Zwicker notin Ladenmann) {
        print "[Zweites Grab]^^Du streichst vorsichtig mit den Fingern durch den feinen Sand auf dem Grab, bis deine Finger etwas ertasten.^^Da ist er, Bills Zwicker!^^Du bläst behutsam den Sand von den Linsen und steckst ihn ein.^";
        SetFlag(F_PINCENEZ_FOUND);
        move Zwicker to player;
        give Zwicker ~concealed;
        InactivateTopic(Ladenmann, 348);
        ActivateTopic(Ladenmann, 349);
    } else if (FlagIsSet(F_PINCENEZ_FOUND) || Zwicker in player || Zwicker in Ladenmann) {
        print "[Zweites Grab]^^Ruhe in Frieden, Mathilda.^";
    } else {
        print "Du siehst nichts Besonderes, und ohne triftigen Grund möchtest du nicht auf dem Grab herumwühlen.^";
    };
];


! ============================================================
! --- 11: WINDRAD ---
! ============================================================

[descWindrad;
    r_Windrad.visitcounter++;
    if (r_Windrad hasnt visited) {
        print "Nach einigen Metern kommst du an das Windrad, das du durch das Fenster deines Zimmers sehen konntest.^^";
    }
    print "Das Windrad ist in etwa fünfzehn Meter Höhe auf einen aus langen Metallstangen bestehenden Gittermast montiert und quietscht bei jeder Bewegung. Eine Heckfahne aus Metall stellt die Rotorblätter automatisch in Windrichtung.^^";
    print "Im Norden geht es zurück zur Ranch. Ein Weg führt nach Westen Richtung Hügelkette.^";
    if (r_Windrad.visitcounter == 3) {
        print "^^Zwei Kojoten schleichen sich bis auf wenige Meter an dich heran. Du nimmst einen Stein und wirft ihn in ihre Richtung, woraufhin sie laut aufheulend Reißaus nehmen.^";
    } else if (r_Windrad.visitcounter == 6) {
        print "^^Einige Kojoten scheinen dich aus einiger Entfernung zu beobachten. Du machst eine beiläufige Wurfbewegung und sie rennen davon.^";
    } else if (r_Windrad.visitcounter == 8) {
        print "^^squieeek ... squieeeeek ...^^Du kannst dieses verdammte Windrad langsam nicht mehr hören, geschweige denn sehen. Wofür ist das Teil überhaupt?^^Du wischst dir den Schweiß von der Stirn und ziehst in Erwägung öfter mal zu laufen, um schneller voranzukommen.^";
    }
];

Room r_Windrad "Windrad"
    with name 'windrad' 'rad' 'mast',
        description descWindrad,
        n_to r_Ranch,
        w_to r_Huegelkette,
        before [;
            Smell: "Du riechst nichts Besonderes.";
            Go:
                if (selected_direction == nw_to or ne_to or e_to or
                    s_to or sw_to or se_to)
                    return PrintDescOOB();
            Climb: "Du bist nicht wirklich schwindelfrei.";
        ];

Object WindradScenery "Windrad" r_Windrad
    with name 'windrad' 'rad' 'fahne' 'heckfahne' 'rotor' 'rotorblätter',
        description "Das Windrad dreht sich leicht im Wind.",
    has scenery neuter;

Object Gittermast "Gittermast" r_Windrad
    with name 'gittermast' 'mast' 'turm',
        description [;
            print "Der Gittermast besteht aus verschweißten Metallstangen.";
            if (Stange hasnt moved)
                print " Eine der Stangen in Bodennähe scheint sich gelöst zu haben.";
            new_line;
        ],
        before [;
            Climb: "Du bist nicht wirklich schwindelfrei.";
        ],
    has scenery;

Object Stange "Metallstange" r_Windrad
    with name 'stange' 'metallstange' 'stangen' 'metallstangen',
        short_name "Metallstange",
        description "Eine etwa drei Meter lange, massive Metallstange.",
        describe [;
            if (self has moved) {
                new_line;
                print "Hier liegt eine Metallstange.";
                rtrue;
            }
            rfalse;
        ],
        before [;
            Take:
                if (self hasnt moved) {
                    print "Du hebelst die Stange hin und her, bis sich die verbliebene Schweißnaht vom Gittermast löst. Sie ist so lang und schwer, dass du sie mit beiden Händen tragen musst.^";
                    give self moved;
                    give self ~concealed;
                    move self to player;
                    rtrue;
                }
                if (FlagIsSet(F_BOULDER_REMOVED)) {
                    "Die Metallstange ist verbogen. Du willst sie nicht mehr mit dir herumtragen.";
                }
                rfalse;
            Drop:
                move self to location;
                print "Du legst die Stange auf den Boden.^"; rtrue;
        ],
    has female concealed;

! ============================================================
! --- 12: HUEGELKETTE ---
! ============================================================

[descHuegelkette;
    if (r_Huegelkette hasnt visited) {
        print "Nach ein paar Minuten Fußmarsch stehst du am Fuße einer niedrigen Hügelkette.^^";
    }
    print "Ein großes Geröllfeld aus größeren und kleineren Felsen erstreckt sich hunderte Meter weit über die gesamte Breite. Die Hügel bieten guten Schutz vor dem Wind, es ist hier beinahe windstill.^^";
    if (FlagIsSet(F_BOULDER_REMOVED)) {
        print "Richtung Norden ist ein etwa schulterhoher, schmaler Durchgang zwischen den Steinen zu erkennen, daneben liegt eine verbogene Metallstange. Einige Schritte weiter liegt der Felsbrocken, der den Stolleneingang zuvor verschlossen hat.^^";
    }
    print "Der Weg im Osten führt zurück zum Windrad vor der Stadt.";
    if (Papagei in player && FlagIsClear(F_BOULDER_DISCOVERED)) {
        print "^^Molly trippelt unruhig auf deiner Schulter auf und ab.";
    } else if (FlagIsSet(F_BOULDER_DISCOVERED) && FlagIsClear(F_BOULDER_REMOVED) && Papagei in r_Huegelkette) {
        print "^^Auf einem Felsbrocken sitzt Molly und flattert aufgeregt mit den Flügeln.";
    }
    new_line;
];

Room r_Huegelkette "Hügelkette"
    with name 'hügelkette' 'hügel' 'berg',
        description descHuegelkette,
        e_to r_Windrad,
        n_to [;
            if (FlagIsSet(F_BOULDER_REMOVED)) return r_Hoehle;
            if (FlagIsClear(F_BOULDER_DISCOVERED))
                "Du siehst keinen Weg in dieser Richtung.";
            if (FlagIsSet(F_CREVICE_WIDENED))
                "Du kannst dich nicht vorbeizwängen, der Spalt ist nicht breit genug.";
            "Du kannst dich nicht vorbeizwängen, der Spalt ist zu schmal.";
        ],
        nw_to [; return self.n_to(); ],
        ne_to [; return self.n_to(); ],
        in_to [; return self.n_to(); ],
        before [;
            Smell:
                if (noun == 0) "Es riecht leicht nach Rauch.";
            Go:
                if (selected_direction == w_to or s_to or sw_to or se_to)
                    return PrintDescOOB();
        ];

[descGeroellfeld;
    if (Papagei in player) {
        SetFlag(F_BOULDER_DISCOVERED);
        InactivateTopic(Barbier, 364);
        move Papagei to r_Huegelkette;
        ActivateTopic(Ladenmann, 345);
        "Du gehst das Geröllfeld auf und ab, als Molly plötzlich aufgeregt zu flattern beginnt und von deiner Schulter auf einen der Felsbrocken hüpft.^^~Braak! BRAAAAK! FEURIOOOO!~";
    }
    if (FlagIsSet(F_BOULDER_REMOVED)) {
        "Richtung Norden ist ein schmaler Durchgang zwischen den Steinen zu erkennen.";
    }
    if (FlagIsSet(F_BOULDER_DISCOVERED))
        "Hier liegt der Brocken, den Molly entdeckt hat.";
    "Du gehst das Geröllfeld auf und ab, kannst aber nichts Besonderes entdecken.";
];

Object Geroellfeld "Geröllfeld" r_Huegelkette
    with name 'steine' 'geröll' 'geröllfeld' 'felsen' 'rauch',
        description [; descGeroellfeld(); rtrue; ],
        before [;
            Smell: "Es riecht leicht nach Rauch.";
        ],
    has scenery neuter;

[descBrocken;
    if (FlagIsSet(F_BOULDER_REMOVED)) {
        "Der Brocken liegt am Ende des Geröllfeldes, zwanzig Schritte vom Stolleneingang.";
    }
    if (FlagIsSet(F_BOULDER_DISCOVERED)) {
        ActivateTopic(Ladenmann, 345);
        if (Papagei in r_Huegelkette) {
            print "Auf dem Felsbrocken sitzt Molly und flattert aufgeregt. Als du den Brocken genauer untersuchst, erkennst du einen offenbar größeren Hohlraum hinter einem ";
        } else {
            print "Hinter dem Brocken ist ein größerer Hohlraum durch einen ";
        }
        if (FlagIsSet(F_CREVICE_WIDENED)) print "schmalen";
        else print "daumenbreiten";
        " Spalt.";
    }
    if (Papagei in player) {
        descGeroellfeld();
        rtrue;
    }
    "Du kannst nichts Besonderes erkennen.";
];

Object Brocken "Felsbrocken" r_Huegelkette
    with name 'brocken' 'felsbrocken' 'fels' 'stein' 'felsen',
        description [; descBrocken(); rtrue; ],
        before [;
            Take, Push, Pull:
                if (FlagIsSet(F_BOULDER_REMOVED))
                    "Der Brocken liegt ganz gut da.";
                if (FlagIsSet(F_BOULDER_DISCOVERED))
                    "Du kommst ohne Werkzeug nicht weiter.";
                "Du willst hier nicht ziellos herumsuchen.";
        ],
    has scenery;

Object Spalt "Spalt" r_Huegelkette
    with name 'spalt' 'spalte' 'lücke' 'felsspalte' 'hohlraum' 'loch' 'luftzug' 'stollen' 'stolleneingang',
        description [;
            if (FlagIsSet(F_BOULDER_REMOVED)) {
                "An Stelle des Felsens ist jetzt ein Stolleneingang sichtbar.";
            }
            print "Hinter einem ";
            if (FlagIsSet(F_CREVICE_WIDENED)) print "schmalen";
            else print "daumenbreiten";
            " Spalt befindet sich ein größerer Hohlraum. Du spürst einen Luftzug.";
        ],
        before [;
            Open: "Mit bloßen Händen kannst du den Spalt nicht öffnen.";
            Receive: <<UseTogether noun self>>;
            Unlock: <<UseTogether second self>>;
            Smell: "Es riecht deutlich nach Rauch.";
        ],
    has scenery;

! ============================================================
! --- 13: MINE ---
! ============================================================

Constant CS_MINE_HILLCHAIN = 195;
Constant CS_MINE_ENTRANCE  = 196;
Constant CS_MINE_SMOKE     = 197;
Constant CS_MINE_SHRUB     = 198;

[descMine;
    if (r_Mine hasnt visited) {
        print "Nach einem kurzen Stück staubiger Straße erhebt sich eine niedrige Hügelkette vor dir. Einige Minuten später erkennst du den Eingang zu einer Mine.^^";
    }
    print "Der Eingang der Mine wird zu beiden Seiten von Fackeln erhellt. Eine dünne Rauchfahne zieht am höchsten Punkt des Stollens nach oben und verliert sich schnell im Wind.^^";
    print "An einem leeren Karren lehnt ein hohläugiger Mann mit zerzaustem schwarzem Haar und spielt mit seinem Gewehr herum.";
    if (Taschentuch in r_Mine)
        print "^^Am Wegrand blitzt etwas Weißes hinter einem kleinen Strauch hervor.";
    "^^Der Weg nach Osten führt zurück in die Stadt.";
];

[descMinemannExamine;
    print "Als du näher herangehst, richtet der Mann sein Gewehr auf dich.^^";
    if (Minenmann has general)
        print "~Sach ma hörst du schlecht? Verpiss dich!~";
    else {
        print "~Verpiss dich von hier, aber schnell!~";
        give Minenmann general;
    }
    "^^Du hebst entschuldigend die Hände und gehst zurück.";
];

[descMineStrauch;
    Examine:
        if (Taschentuch in r_Mine)
            "Neben dem Strauch liegt ein Taschentuch, halb von Sand bedeckt.";
        "Ein kleiner Strauch steht am Wegrand.";
    default: rfalse;
];

Room r_Mine "Mine"
    with description descMine,
        cheap_scenery
            CS_ADD_LIST r_Mine (sc1),
        sc1
            CS_MINE_HILLCHAIN 4 'hügelkette' 'hügel' 'berg' 'kette' "Die Hügelkette erstreckt sich von Nordosten nach Süden."
            CS_MINE_ENTRANCE 6 'mine' 'eingang' 'mineneingang' 'karren' 'fackel' 'fackeln' "Bis auf ein paar leere Karren und Fackeln kannst du am Eingang der Mine nicht viel erkennen."
            CS_MINE_SMOKE 3 'rauch' 'fahne' 'rauchfahne' "Konstant dringt schwarzer Rauch aus der Mine. Vielleicht von den Fackeln, die dort unten brennen."
            CS_MINE_SHRUB 3 'strauch' 'busch' 'wegrand' descMineStrauch,
        e_to r_Ranch,
        w_to [; <<Examine Minenmann>>; ],
        before [;
            Go:
                if (selected_direction == n_to or nw_to or ne_to or
                    s_to or sw_to or se_to)
                    return PrintDescOOB();
            Smell:
                if (noun == 0) "Es riecht leicht nach Rauch.";
            Enter:
                if (cs_match_id == CS_MINE_ENTRANCE)
                    "Viel zu weit weg und gut bewacht. Vielleicht musst du einen anderen Weg finden.";
        ];

Object Minenmann "Mann" r_Mine
    with name 'mann' 'wachmann' 'minenmann' 'haar' 'gewehr',
        description descMinemannExamine,
        before [;
            Attack, Talk, Tell, Ask, Show, Give, Order:
                descMinemannExamine(); rtrue;
            Use:
                "Du kannst ihn nicht einfach über den Haufen schießen. Vielleicht gibt's ja noch einen anderen Weg in die Mine.";
            UseTogether:
                if (noun == Revolver || second == Revolver)
                    "Du kannst ihn nicht einfach über den Haufen schießen. Vielleicht gibt's ja noch einen anderen Weg in die Mine.";
                rfalse;
        ],
    has animate concealed;

Object Taschentuch "Taschentuch" r_Mine
    with name 'taschentuch' 'tuch' 'monogramm',
        description "Ein weißes Taschentuch mit einem Monogramm. Die Buchstaben 'L.T.' sind zu erkennen.",
        before [;
            Take:
                if (Taschentuch in r_Mine) {
                    print "Du steckst das Taschentuch ein.^";
                    give Taschentuch ~concealed;
                    move Taschentuch to player;
                    ActivateTopic(Barbier, 370);
                    ActivateTopic(Barfrau, 307);
                    ActivateTopic(Sheriff, 325);
                    rtrue;
                }
            Smell: "Es riecht nach Lavendel und bitteren Tränen.";
        ],
    has neuter concealed;

Object TaschentuchWeiss "etwas Weißes" r_Mine
    with name 'weißes' 'weiß' 'etwas',
        description "Es ist ein Taschentuch.",
        before [;
            Take:
                print "Es ist ein Taschentuch. Du steckst es ein.^";
                give Taschentuch ~concealed;
                move Taschentuch to player;
                remove TaschentuchWeiss;
                ActivateTopic(Barbier, 370);
                ActivateTopic(Barfrau, 307);
                ActivateTopic(Sheriff, 325);
                rtrue;
        ],
    has scenery;

! ============================================================
! --- 14: HOEHLE ---
! ============================================================

[descHoehle;
    if (r_Hoehle hasnt visited) {
        print "Du zwängst dich durch den engen Spalt. Nach einigen Metern kannst du bequem stehen und dich frei bewegen.^^";
    }
    print "Die Luft ist angenehm kühl und feucht. Es riecht leicht nach Rauch. ";
    if (Lampe in player && Lampe has on)
        print "Ein großer, spitzer Felsbrocken markiert den Rand eines Abgrunds im Norden.";
    else
        print "Du kannst kaum die Hand vor Augen sehen.";
    if (FlagIsSet(F_ROPE_TIED))
        print "^^Ein Seil ist an den Felsen gebunden.";
    print "^^Im Süden dringt fahles Licht durch den langen, schmalen Höhleneingang.^";
];

Room r_Hoehle "Höhle"
    with name 'höhle' 'stollen' 'mine' 'gang',
        description descHoehle,
        s_to r_Huegelkette, out_to r_Huegelkette,
        before [;
            Go:
                if (selected_direction == n_to or d_to) {
                    if (Lampe in player && Lampe has on) {
                        if (FlagIsSet(F_ROPE_TIED)) {
                            if (r_Gewoelbe hasnt visited) {
                                print "Du nimmst den Henkel der Petroleumlampe zwischen die Zähne und greift mit beiden Händen das Seil.^^Die Füße gegen die Felswand gestemmt, seilst du dich langsam ab.^";
                                doScreenbreak();
                            }
                            PlayerTo(r_Gewoelbe);
                            rtrue;
                        }
                        print "Der Abgrund ist viel zu steil um ohne Hilfsmittel gefahrlos hinunter klettern zu können, vor allem wenn du dabei noch die Lampe halten musst.^";
                        if (Seil notin player) {
                            give HoehleAbgrund general;
                            ActivateTopic(Ladenmann, 355);
                            ActivateTopic(Barfrau, 311);
                        }
                    } else {
                        if (Spitzfelsen hasnt general) print "Du tastest dich vorsichtig vor...^^Aua! Du hast dir das Schienbein an einem grösseren Felsen gestossen.^^";
                        print "Es ist wirklich zu dunkel hier, um weiterzugehen, du könntest dich ernsthaft verletzen.^";
                        give Spitzfelsen general;
                        ActivateTopic(Ladenmann, 353);
                        ActivateTopic(Barfrau, 309);
                    }
                    rtrue;
                }
                if (selected_direction == e_to or w_to or ne_to or nw_to or se_to or sw_to)
                    "Du tastest die Wand vorsichtig ab. Hier geht es nicht weiter.";
            Tie:
                if (noun == Seil || second == Seil) {
                    <<UseTogether Seil Spitzfelsen>>;
                }
                "Hier gibt es nichts sinnvolles zum Festbinden.";
            Smell: "Es riecht leicht nach Rauch und feuchtem Stein. Und irgendwie leicht süßlich, ein dir bislang völlig unbekannter Geruch.";
        ];

Object Spitzfelsen "Felsen" r_Hoehle
    with name 'felsen' 'felsbrocken' 'brocken' 'stein' 'spitzfelsen',
        description [;
            if (Lampe in player && Lampe has on)
                "Ein mannshoher, spitzer Felsen steht direkt am Rand eines Abgrunds.";
            "Der Felsen fühlt sich feucht und glatt an.";
        ],
        before [;
            Examine: give self general;
            Receive: <<UseTogether noun self>>;
        ],
    has scenery;

Object HoehleAbgrund "Abgrund" r_Hoehle
    with name 'abgrund' 'loch' 'tiefe' 'abgrund',
        description [;
            if (Lampe notin player || Lampe hasnt on) {
                "Du kannst nichts erkennen.";
            } else if (self has general) {
                "Trotz Lampe kannst du keinen Boden erkennen. Es ist auf jeden Fall zu tief, um zu springen.";
            } else {
                give self general;
                ActivateTopic(Ladenmann, 355);
                ActivateTopic(Barfrau, 311);
                "Du stehst am Rande eines Abgrunds. Trotz Lampe kannst du keinen Boden erkennen.^^Du schiebst mit dem Fuß einige Kiesel über den Rand und lauschst in die Dunkelheit...^^Plopp!^^Klingt nach festem Boden, vielleicht fünf Meter, vielleicht auch zehn Meter tief. Auf jeden Fall zu tief, um zu springen.";
            }
        ],
    has scenery neuter;

! ============================================================
! --- 15: GEWOELBE ---
! ============================================================

Constant CS_VAULT_STUFF  = 200;
Constant CS_VAULT_ENTRY  = 201;
Constant CS_VAULT_TORCHES = 202;

[descGewoelbe;
    if (r_Gewoelbe hasnt visited) {
        print "Nach einer gefühlten Ewigkeit ertasten deine Füße endlich wieder festen Boden. Der Schweiß läuft dir den Rücken hinunter, als du dich von der Wand abwendest. Dein angestrengtes Keuchen malt kleine Dampfwölkchen in den Schein deiner Laterne.^^";
        print "Ein tiefes, offenbar nicht weit entferntes Rumpeln lässt dich blitzartig verstummen. Vorsichtig folgst du dem fahlen Lichtschein des gekrümmten Stollengangs vor dir.^^";
        print "Als sich der Gang weitet und immer heller wird, kannst du immer deutlicher Stimmen vernehmen. Vorsichtig gehst du hinter einem hüfthohen Steinvorsprung in Deckung, von dem du das große, mit unzähligen Fackeln erleuchtete Gewölbe unter dir überblicken kannst.^^";
        doScreenbreak();
        give Taschentuch ablegbar;
    }
    if (FlagIsSet(F_VAULT_SHOWDOWN)) {
        print "Mehrere Männer laufen vom Höhleneingang hinab in eure Richtung, einige mit gezogenen Waffen. Du nimmst die Situation wie in Zeitlupe wahr. Deine rechte Hand zuckt leicht.";
        if (vault_death_count > 1) {
            print "^^Am Höhleneingang im Osten springt dir ein mit Fässern beladener Karren ins Auge.";
        }
        if (vault_death_count > 2) {
            print " Ein großer Holzkeil blockiert eines der Räder.";
        }
        "^";
    }
    if (FlagIsSet(F_LUCY_LISTENING)) {
        descVaultThompson();
        SetFlag(F_VAULT_SHOWDOWN);
        rtrue;
    }
    if (FlagIsSet(F_LUCY_FREE)) {
        print "Lucy und Michael stehen gebückt im Halbdunkel neben ihrem ehemaligen Gefängnis.^^";
    } else {
        print "Etwa ein Dutzend Männer scheint in einiger Entfernung an verschiedenen Stationen zu arbeiten. Einige rühren in großen befeuerten Stahlkesseln, andere hantieren mit großen, mit Tüchern bespannten Bottichen, wieder andere scheinen so etwas wie Fladen auszuwalzen und Kugeln zu formen. Es stinkt ziemlich und dir wird etwas schwummrig.^^";
        print "Nur wenige Meter von dir entfernt befindet sich eine größere Felsnische. Hinter zusammengebundenen Gittern kauert ein junges Paar auf dem Boden";
        if (FlagIsClear(F_GUARD_OUT)) {
            print " und flüstert manchmal miteinander. Das ist Lucy! Dann muss der junge Mann wohl Michael sein.";
        } else {
            print " und rüttelt an den Gitterstäben. Sie gestikulieren wild in deine Richtung.";
        }
        new_line;
    }
    if (FlagIsClear(F_GUARD_OUT) && Geselle hasnt general) {
        print "^^Davor sitzt ein mürrisch dreinschauender Geselle auf einem Stein, die Arme auf die Oberschenkel gestützt, mit einer Flinte in der rechten Hand.";
        new_line;
    }
];

[descVaultThompson;
    print "^^Ein sehr gepflegt aussehender Mann in mittlerem Alter mit Stock und Melone sowie ein deutlich schmutzigerer, wild gestikulierender Bursche schlendern in eure Richtung und bleiben nur ein paar Meter entfernt stehen.^^";
    print "~Was sollen wir denn sonst machen, Ron? Die singen doch sofort, wenn wir die jetzt rauslassen!~^^";
    print "~Für dich immer noch Mr. Thompson, Cal. Ich werde mit Lucy reden, wenn sie sich etwas beruhigt hat, dann sehen wir weiter.~ Ah, das muss dann wohl Calvin Mifflin sein!";
    doScreenbreak();
    print "Der junge Mann blickt zu Boden und schüttelt den Kopf. ~Na ich weiß nicht Ro-- Mr. Thompson. Die hat ganz schön Haare auf den Zähnen.~^^";
    print "Mit einer schnellen, fast beiläufigen Bewegung holt Thompson mit dem Stock aus und lässt den Knauf blitzschnell auf das linke Knie des Mannes niedersausen. ~AAAARGH!~ schreit dieser überrascht auf und klappt augenblicklich zusammen.^^";
    print "Als wäre nichts geschehen spricht Thompson mit gleichbleibend sonorer Stimme weiter. ~Es steht dir nicht zu, so über sie zu sprechen. Wenn sie und ihr Stallbursche nicht zur Besinnung kommen, werden wir leider eine andere Lösung finden müssen.~^^";
    print "Lucy läuft purpurrot an. ~DU VERDAMMTER---~^^";
    doScreenbreak();
    print "Michael presst Lucy schnell eine Hand auf den Mund, doch es ist zu spät. Thompson tritt zwei Schritte zur Seite, um in die Nische zu blicken. Seine Augen weiten sich.^^";
    print "~Die Gefangenen sind frei! Hierher, sofort!~^^";
    "Mehrere Männer blicken auf und laufen vom Höhleneingang hinab in eure Richtung, einige greifen nach ihren Waffen.";
];

Room r_Gewoelbe "Gewölbe"
    with name 'gewölbe' 'höhle' 'stollen' 'gang' 'vorsprung',
        description descGewoelbe,
        cheap_scenery
            CS_ADD_LIST r_Gewoelbe (sc1),
        sc1
            CS_VAULT_STUFF 6 'stationen' 'kessel' 'stahlkessel' 'bottich' 'bottiche' 'faden' "Du kannst von hier aus nichts Genaueres erkennen, es interessiert dich im Moment aber auch nicht weiter."
            CS_VAULT_TORCHES 3 'fackel' 'fackeln' 'licht' "Die Fackeln tauchen das Gewölbe in ein flackerndes orangefarbenes Licht."
            CS_VAULT_ENTRY 5 'karren' 'rad' 'raeder' 'faesser' 'fass' descVaultEntry,
        u_to r_Hoehle,
        before [;
            Go:
                if (selected_direction == s_to or u_to) {
                    if (selected_direction == s_to) selected_direction = u_to;
                    if (FlagIsSet(F_VAULT_SHOWDOWN)) {
                        print "Du packst Lucy und Michael und schiebst sie Richtung Felsvorsprung. Kugeln zischen an euren Köpfen vorbei, und als du dich umdrehst, fühlst du einen gellenden Schmerz in der linken Schulter, der dich zu Boden wirft.";
                        doVaultDeath();
                        rtrue;
                    }
                    if (FlagIsClear(F_LUCY_FREE)) {
                        "Du kannst die beiden jetzt nicht im Stich lassen.";
                    }
                    rtrue;
                }
                if (selected_direction ~= u_to && selected_direction ~= s_to)
                    "Da kannst du nicht hingehen.";
            Smell: "Rauch und verschiedene Dämpfe vermischen sich hier auf unangenehme Weise zu einem süßlichen, leicht stehenden Geruch. Du fühlst dich leicht benebelt.";
            Drop:
                if (noun == Taschentuch) {
                    if (Geselle has general && FlagIsClear(F_LUCY_FREE)) {
                        "Du kannst das Taschentuch hier nicht fallen lassen.";
                    }
                    if (FlagIsSet(F_LUCY_FREE)) {
                        "Lucy und Michael sind bereits frei. Du brauchst das Taschentuch jetzt noch für den Sheriff.";
                    }
                    if (Geselle hasnt general && FlagIsClear(F_LUCY_FREE)) {
                        print "Du nimmst das leuchtend weiße Taschentuch in die Hand und lässt es über den Rand des Felsvorsprungs gleiten, als die Wache kurz zu den Gefangenen schaut.^^";
                        print "Einen Moment später dreht der Mann den Kopf wieder in deine Richtung und runzelt irritiert die Stirn. Er steht auf, kommt langsam in deine Richtung und bückt sich direkt vor dir nach dem Taschentuch.^^";
                        print "'Wo zum Teufel kommt das denn her?'^";
                        give Geselle general;
                        give Geselle ~concealed;
                        rtrue;
                    }
                    rfalse;
                }
            Attack:
                if (noun == Geselle) {
                    if (Geselle has general) {
                        <<UseTogether Revolver Geselle>>;
                        rtrue;
                    }
                    "Er ist zu weit weg und schaut außerdem immer wieder in deine Richtung.";
                }
                rfalse;
        ];

[descVaultEntry;
    Examine:
        "Am Höhleneingang im Osten steht ein mit Fässern beladener Karren.";
    default: rfalse;
];

Object Geselle "Geselle" r_Gewoelbe
    with name 'geselle' 'mann' 'wache' 'wächter' 'wachmann' 'flinte' 'hinterkopf' 'arm' 'arme',
        description [;
            if (self has general)
                "Ein einladender Hinterkopf mit trockenem schwarzem Haar.";
            if (self has concealed)
                "Die Wache liegt mit dem Gesicht voraus im Dreck und rührt sich nicht mehr.";
            "Der Mann blickt mürrisch vor sich auf den Boden und scharrt mit den Füßen im Sand. Gelegentlich wirft er einen Blick auf das junge Paar in dem behelfsmäßigen Käfig oder lässt seinen Blick in deine Richtung schweifen, aber du bist im Halbdunkel hinter dem Felsvorsprung offenbar nicht zu erkennen.";
        ],
        before [;
            Talk, Tell, Ask, AskFor, Show, Give:
                if (self has concealed) "Der sagt nicht mehr viel.";
                "Keine gute Idee. Er könnte um Hilfe rufen.";
            UseTogether:
                if (second == Revolver or Brecheisen or Schaufel) {
                    if (self hasnt general) "Du musst ihn zuerst ablenken.";
                    if (self has concealed) "Ich glaube der hat erstmal genug.";
                    print "BAUZ! Du streckst den Mann mit einem gezielten Schlag mit ";
                    if (second == Brecheisen) print "dem Brecheisen"; else print "der Schaufel"; print " nieder.^^Du siehst dich verstohlen um, aber keiner der Arbeiter scheint etwas gehört zu haben. Du steckst das leuchtende Taschentuch schnell wieder ein.^";
                    give self concealed;
                    give self ~general;
                    give Taschentuch ~ablegbar;
                    SetFlag(F_GUARD_OUT);
                    InactivateTopic(Lucy, 390);
                    InactivateTopic(Lucy, 391);
                    InactivateTopic(Lucy, 392);
                    InactivateTopic(Lucy, 393);
                    ActivateTopic(Lucy, 400);
                    rtrue;
                }
                rfalse;
        ],
    has animate concealed;

Object Michael "Bursche" r_Gewoelbe
    with name 'bursche' 'michael' 'mann' 'junger',
        description "Der junge Mann legt immer wieder seine Hand auf den Arm seiner Begleitung oder streicht ihr beruhigend über das Gesicht.",
        before [;
            Talk, Tell, Ask: <<Talk Lucy>>;
        ],
    has animate concealed;

Object VaultNische "Felsnische" r_Gewoelbe
    with name 'nische' 'felsnische' 'kaefig' 'gitter' 'gitterstabe' 'stabe',
        description [;
            if (FlagIsSet(F_LUCY_FREE))
                "Lucy und Michael stehen gebückt im Halbdunkel neben ihrem ehemaligen Gefängnis.";
            if (Geselle has concealed)
                "Lucy und Michael rütteln an den Gitterstäben und gestikulieren wild in deine Richtung.";
            "Nur wenige Meter von dir entfernt befindet sich eine größere Felsnische. Hinter zusammengebundenen Gittern kauert ein junges Paar.";
        ],
    has scenery;

Object VaultThompson "Thompson" r_Gewoelbe
    with name 'thompson' 'mann' 'buergermeister' 'stiefvater' 'stock' 'melone' 'hut',
        description "Ein sehr gepflegt aussehender Mann in mittlerem Alter mit Stock und Melone.",
        before [;
            Talk, Tell, Ask: "Jetzt ist Zeit zu handeln, nicht zu sprechen.";
        ],
    has animate concealed;

Object VaultKarren "Karren" r_Gewoelbe
    with name 'karren' 'rad' 'raeder' 'faesser' 'fass',
        description [;
            if (FlagIsSet(F_VAULT_SHOWDOWN)) {
                print "Ein Karren mit vier Speichenrädern, mit mehreren Holzfässern beladen.^^";
                "Ein großer Holzkeil unter einem der Räder hindert den Karren daran wegzurollen.";
            }
            "Am Höhleneingang im Osten steht ein mit Fässern beladener Karren.";
        ],
        before [;
            Take: "Der ist viel zu weit weg.";
        ],
    has scenery concealed;

Object VaultKeil "Holzkeil" r_Gewoelbe
    with name 'keil' 'holzkeil',
        description [;
            if (FlagIsSet(F_VAULT_SHOWDOWN))
                "Ein großer Holzkeil blockiert eines der Räder und hindert den Karren daran wegzurollen.";
            "Am Höhleneingang im Osten steht ein mit Fässern beladener Karren, eines der Vorderräder mit einem Holzkeil arretiert.";
        ],
        before [;
            Take: "Da kommst du nicht ran. Du musst ihn irgendwie anders entfernen.";
        ],
    has scenery concealed;

Object Maenner "Männer" r_Gewoelbe
    with name 'männer' 'maenner' 'mann' 'banditen' 'verbrecher' 'arbeiter' 'buergermeister' 'mifflin',
        description [;
            if (FlagIsSet(F_VAULT_SHOWDOWN))
                "Die Männer kommen auf euch zu. Obwohl sie rennen, nimmst du ihre Bewegungen wie in Zeitlupe wahr.";
            "Fast alle wirken sehr beschäftigt.";
        ],
        before [;
            Talk, Tell, Ask: "Jetzt ist Zeit zu handeln, nicht zu sprechen.";
        ],
    has scenery concealed;

! ============================================================
! --- 16: STEPPE (ENDING) ---
! ============================================================

[descSteppe;
    if (r_Steppe hasnt visited) {
        print "Frisch gesattelt sitzt du auf Billy, einem jungen Hengst, deine Umhängetasche fest im Griff. Die langsam untergehende Sonne wirft lange Schatten auf den staubigen Weg vor dir, der nach Osten aus der Stadt führt.^^";
        print "Du blickst dich noch einmal um und hebst die Hand in Richtung ";
        if (Barfrau has proper) print "Ella, ";
        print "Marten und Bill, die dir auf der Straße stehend nachwinken.^^";
        print "Den Blick nach vorne gerichtet versetzt du den Rappen in einen leichten Trab. Ein weiter Weg liegt noch vor dir.^^";
        style underline;
        print "Wieso dachtest du, dass ich im Gefängnis sitze, Claire? Wer hat dir das erzählt?";
        style roman;
        print "^^Egal. Du würdest sie finden, und bald würdet ihr wieder zusammen sein, dessen warst du dir sicher... doch das war eine Geschichte, die an einem anderen Tag erzählt werden sollte.";
        doScreenbreak();
        print "^^";
        style bold; print "                 @@126@@126@@126 FIN @@126@@126@@126"; style roman;
        doScreenbreak();
        print "^Vielen Dank, dass du "; style bold; print "Staub"; style roman; print " gespielt hast. Ich hoffe, es hat dir gefallen.^^Wenn ja, würde ich mich sehr über eine Bewertung auf IFDB.org freuen - vielleicht erfährst du dann bald, wie die Geschichte endet. Gerne nehme ich Anregungen, Lob und Kritik gerne auch in https://bit.ly/Ikes-Discord oder per Mail an staub@@64ikeserver.de entgegen.^^Vielen Dank an Olaf Nowacki, Hannes Schüller, Michael L. und meine Familie für ihr hilfreiches Feedback sowie den GerX-/deform-Autoren für die deutsche Inform-Erweiterung. Das Cover wurde mit Hilfe von Stable Diffusion XL erstellt.^^2024 (c) IkeC^";
        rtrue;
    }
    rtrue; ! game is over — suppress room description after credits
];

Room r_Steppe "Steppe"
    with name 'steppe' 'weg' 'strasse',
        description descSteppe,
        before [;
            Go: "Du kannst leider nirgendwo mehr hingehen. Die Geschichte ist hier zu Ende.";
        ];

Object Billy "Billy" r_Steppe
    with name 'billy' 'pferd' 'hengst' 'rappe',
        description "Billy peitscht schnell wie der Wind und mittlerweile in vollem Galopp über die Steppe.",
        before [;
            Exit: "Du hast schon genug Zeit verloren. Claire könnte in Gefahr sein.";
        ],
    has animate proper scenery;

! ============================================================
! --- SHERIFF ENDING TALK ARRAY ---
! ============================================================

[sh_e_passiert;
    print "Dunder steht auf und legt Lucy eine Hand auf die Schulter.^^'Nun, soweit ich die beiden hier richtig verstanden habe, hast du ihnen das Leben gerettet nachdem in der Höhle ein Karren mit Nitrofässern losgerollt und explodiert ist.'^^Er blinzelt dich listig an. ~So ein Zufall, was?~^";
    ActivateTopic(Sheriff, 412);
    ActivateTopic(Sheriff, 413);
];

[sh_e_kopf;
    print "Michael fasst sich an den Kopf und rückt seinen Verband etwas zurecht.^^'Ach, das geht schon wieder. Hat wohl ganz schön geblutet, als sie uns gefunden haben, aber Marten hat sich das angesehen und gleich verbunden.'^";
    ActivateTopic(Sheriff, 414);
];

[sh_e_michael;
    print "'Hatte gehört, dass in der Mine wohl nicht alles mit rechten Dingen zugehen soll und auch Thompson seine Finger mit im Spiel hat. Als Cal und Bob dann am Abend bei Ella aufgetaucht sind und es da hoch her ging, dachte ich, das wäre ein guter Zeitpunkt da mal nachzusehen.'^^Als Michael Lucys vorwurfsvollen Blick bemerkt, hebt er entschuldigend die Arme. ~Ich wollt's dir erst sagen, aber hätte ja auch einfach leeres Gerede sein können. Immerhin geht's um deinen Va-- ähm, Stiefvater.~^^Lucy holt tief Luft und er spricht schnell weiter. ~Jedenfalls war die Mine leider nicht so verlassen wie ich dachte, ich wurde entdeckt und eingesperrt.~^";
];

[sh_e_hoehle;
    print "Lucy steht hastig auf. Ihre Unterlippe zittert.^^'Diese Penner haben da irgendeinen Dreck zum Rauchen hergestellt! Und das nach all dem, was mit meiner Mutter war!'^^Sie ringt um Fassung und dreht sich zu Michael um, der sie in den Arm nimmt.^";
    ActivateTopic(Sheriff, 415);
];

[sh_e_mutter;
    print "Michael wendet sich dir zu. ~Lucys Mutter hat wohl Opium geraucht und wurde irgendwann sehr krank. Sie ist leider letztes Jahr verstorben.~^^Lucy weint. ~Ich habe nie genau verstanden, was mit ihr los war. Dieses Arschloch! Mein richtiger Vater hätte das niemals zugelassen!~^";
    ActivateTopic(Sheriff, 416);
];

[sh_e_thompson;
    print "Dunder seufzt und hebt die Hände.^^'Den haben wir leider noch nicht. Deputy Miller war als Erster am Mineneingang nach der Explosion. Ein paar der Banditen haben's wohl hustend und kriechend nach draußen geschafft. Um die hat sich Marten gekümmert.'^^Er setzt sich neben Lucy. ~Die meisten anderen hatten nicht so viel Glück. Cal Mifflin ist tot, seinen Bruder Bob haben wir hinten in der Zelle. Miller musste über einige Leichen steigen, bevor er euch da hinten gefunden hat.~^^Über Leichen steigen... Die furchtbaren Erinnerungen an die Ereignisse von Red Rock bohren sich kurz einen Weg in dein Bewusstsein, und ein kalter Schauer läuft dir über den Rücken.^";
    ActivateTopic(Sheriff, 417);
];

[sh_e_drogen;
    print "'Wir gehen davon aus, dass sie Chandu produziert haben.'^^Der Sheriff blickt in dein fragendes Gesicht und lacht. ~Ja, ungefähr so hab' ich auch erst geschaut, aber Marten hat's mir erklärt. Du kennst dieses Opiumzeug, das die Chinamänner rauchen? Der Gouverneur duldet es zwar noch, aber es wird hier nicht mehr gern gesehen. Macht die Leute nur krank.~^^Er zieht einen Flachmann aus der Tasche, nimmt einen Schluck und hält ihn dir hin. Du nimmst dankbar an.^^'Also, die schaffen wohl Opium in die Höhle, machen dann alles Mögliche damit und am Ende kommen dann so kleine Kugeln bei raus. Die lassen sich wohl einfacher verkaufen, und Marten meint, dass die mit Pflanzenfasern oder sowas gestreckt sind, daher auch die ganze Heimlichtuerei.'^";
    ActivateTopic(Sheriff, 418);
];

[sh_e_aufwand;
    print "Dunder nickt. ~Nun, das Zeug verdirbt wohl ziemlich schnell, wenn es nicht mehr rein ist, und draußen an der frischen Luft funktioniert die Produktion wohl nicht. Keine Ahnung. Denke das Zeug wurde dann möglichst schnell in der Stadt vertickt.~^^Er blickt zur Tür. ~Wenn Bob aufwacht und wir Thompson haben, gibt's vielleicht mehr Antworten.~^^Antworten... plötzlich fällt dir wieder ein, was dich eigentlich an diesen Ort geführt hat, und nimmst die Zeichnung aus deiner Weste, die du am Tag davor schon einigen Leuten in der Stadt gezeigt hast.^";
    ActivateTopic(Sheriff, 419);
];

[sh_e_frau;
    print "Du zeigst Michael die Zeichnung. Er studiert sie eingehend und lächelt.^^'Aber sicher! Diese Frau kam neulich drüben spätabends bei der Ranch an. Ihr Gaul ist fast unter ihr zusammengebrochen, und sie sah auch aus, als könne sie dringend eine Mütze Schlaf vertragen.'^^Er gibt dir die Zeichnung zurück. ~Habe ihr angeboten bei Ella nach einem Zimmer zu fragen, aber sie wollte nicht. Ich habe sie dann im Heu schlafen lassen und ihr Pferd versorgt. Als ich am nächsten Morgen nach ihr sehen wollte, waren sie und ihr Pferd verschwunden.~^";
    ActivateTopic(Sheriff, 420);
];

[sh_e_wohin;
    print "'Sie hatte mir am Abend ein paar Dollar gegeben und gesagt, sie wolle in die Stadt, weil ihr Mann wohl dort im Militärgefängnis sitze.'^^";
    style underline; print "Oh Claire, nein!"; style roman;
    new_line;
    ActivateTopic(Sheriff, 421);
];

[sh_e_dorthin;
    print "~Militärgefängnis, was? Nun, aktuell bist du jedenfalls sauber, das habe ich schon prüfen lassen.~ Dunder öffnet die Schublade seines Schreibtischs und reicht dir deinen Einberufungsbescheid.^^'Die Männer des Gouverneurs werden bald hier sein, um Thompson zu finden und Mifflin zu befragen.'^^Michael räuspert sich. ~Ähm, wir haben uns noch gar nicht richtig bedankt für alles, was Sie für uns getan haben. Also... vielen Dank.~^^Er gibt dir etwas unbeholfen die Hand. Lucy blickt dich an, die Augen gerötet, und umarmt dich kurz und fest.^";
    move Einberufungsbescheid to player;
    ActivateTopic(Sheriff, 422);
];

[sh_e_taschentuch;
    print "Lucys verweintes Gesicht hellt sich auf. ~Danke!~^^Sie nimmt das Taschentuch aus deiner Hand und schnäuzt die Nase.^^'Wir haben leider nicht viel Geld, und die Kohle meines Stiefvaters rühre ich nicht an. Wir würden Ihnen aber gerne Billy anbieten, das ist unser schnellstes Pferd.'^^Sie blickt zu Michael, der eifrig nickt.^^'Bringen Sie ihn einfach zu meinem Cousin Marc in der Tanner Street, wenn Sie in der Stadt angekommen sind.'^^Du nimmst dankend an und stehst auf.^";
    remove Taschentuch;
    endingCleanup();
];

Array talk_array_sheriff_ende -->
    TM_ACTIVE 411 "~Was ist passiert?~"
        TM_NO_LINE
        sh_e_passiert
    TM_INACTIVE 412 "~Wie geht's Ihrem Kopf, Michael?~"
        TM_NO_LINE
        sh_e_kopf
    TM_INACTIVE 414 "~Was wollten Sie überhaupt da?~"
        TM_NO_LINE
        sh_e_michael
    TM_ACTIVE 413 "~Was haben die da in der Höhle getrieben?~"
        TM_NO_LINE
        sh_e_hoehle
    TM_INACTIVE 415 "~Was war denn mit Ihrer Mutter?~"
        TM_NO_LINE
        sh_e_mutter
    TM_ACTIVE 416 "~Wo ist Thompson?~"
        TM_NO_LINE
        sh_e_thompson
    TM_INACTIVE 417 "~Was genau haben die denn hergestellt?~"
        TM_NO_LINE
        sh_e_drogen
    TM_INACTIVE 418 "~Was für ein Aufwand!~"
        TM_NO_LINE
        sh_e_aufwand
    TM_INACTIVE 419 "~Michael, kennen Sie diese Frau?~"
        TM_NO_LINE
        sh_e_frau
    TM_INACTIVE 420 "~Wo wollte sie hin?~"
        TM_NO_LINE
        sh_e_wohin
    TM_INACTIVE 421 "~Ich muss so schnell wie möglich dorthin!~"
        TM_NO_LINE
        sh_e_dorthin
    TM_INACTIVE 422 "~Hier, Ihr Taschentuch. Hat mir sehr geholfen.~"
        TM_SILENT_PLAYER
        sh_e_taschentuch
    TM_END;


